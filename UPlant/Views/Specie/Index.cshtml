@inject LanguageService language
@{
    ViewData["Title"] = "Index";
}

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h1 class="card-title">Elenco</h1>
        @{
            if (User.IsInRole("Administrator"))
            {
                <div class="float-right success ">
                    <a asp-action="Create">
                        <span class="btn btn-success" title="@language.Getkey("Global_Add") @language.Getkey("Global_Species")">
                            @language.Getkey("Global_Add") @language.Getkey("Global_Species")
                        </span>
                    </a>
                </div>
            }
        }
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="table1" class="table table-bordered table-striped dataTable">
                <thead>
                    <tr>
                        <th>@language.Getkey("Global_Scientific_Name")</th>
                        <th>@language.Getkey("Global_Common_Name")</th>
                        <th>@language.Getkey("Global_English_Common_Name")</th>
                        <th>@language.Getkey("Global_Family")</th>
                        <th>@language.Getkey("Global_Genus")</th>
                        <th>@language.Getkey("Global_Floristic_Kingdom")</th>
                        <th>@language.Getkey("Global_Range")</th>
                        <th>@language.Getkey("Global_Cites")</th>
                        <th>@language.Getkey("Global_Iucn") @language.Getkey("Global_Global")</th>
                        <th>@language.Getkey("Global_Iucn") @language.Getkey("Global_Local")</th>
                        <th>@language.Getkey("Global_Notes")</th>
                        <th style="width:25%"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/accessioni.min.css" rel="stylesheet" />
    <link href="~/css/datatables.min.css" rel="stylesheet" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/datatables.min.js"></script>
}

@section CustomScripts {
    <script>
        jQuery(function () {
            const isAdministrator = @User.IsInRole("Administrator").ToString().ToLowerInvariant();
            const editUrlTemplate = '@Url.Action("Edit", "Specie", new { id = "__id__" })';
            const deleteUrlTemplate = '@Url.Action("Delete", "Specie", new { id = "__id__" })';

            jQuery('#table1').DataTable({
                'processing': true,
                'serverSide': true,
                'deferRender': true,
                'paging': true,
                'lengthChange': true,
                'searching': true,
                'ordering': true,
                'info': true,
                'autoWidth': false,
                'pageLength': 25,
                'lengthMenu': [25, 50, 100],
                'searchDelay': 400,
                'ajax': {
                    'url': '@Url.Action("IndexData", "Specie")',
                    'type': 'GET',
                    'dataSrc': function (json) {
                        if (json && json.data && Array.isArray(json.data.$values)) {
                            return json.data.$values;
                        }

                        return json && json.data ? json.data : [];
                    },
                    'error': function (xhr) {
                        console.error('Specie IndexData error', xhr);
                    }
                },
                'columns': [
                    { 'data': 'scientificName' },
                    { 'data': 'commonName' },
                    { 'data': 'englishCommonName' },
                    { 'data': 'family' },
                    { 'data': 'genus' },
                    { 'data': 'kingdom' },
                    { 'data': 'range' },
                    { 'data': 'cites' },
                    { 'data': 'iucnGlobal' },
                    { 'data': 'iucnLocal' },
                    { 'data': 'notePreview' },
                    {
                        'data': null,
                        'orderable': false,
                        'searchable': false,
                        'render': function (data, type, row) {
                            if (!isAdministrator || !row.showActions) {
                                return '';
                            }

                            const editUrl = editUrlTemplate.replace('__id__', row.id);
                            let actions = '<a href="' + editUrl + '"><span class="btn btn-warning btn-xs"><i class="fa-solid fa-pencil" style="color: #fafafa;"></i></span></a>';

                            if (row.canDelete) {
                                const deleteUrl = deleteUrlTemplate.replace('__id__', row.id);
                                actions += ' <a href="' + deleteUrl + '"><span class="btn btn-danger btn-xs"><i class="fa-solid fa-trash"></i></span></a>';
                            }

                            return actions;
                        }
                    }
                ]
            });
        })
    </script>
}
