@model UPlant.Models.DB.ValidazioneTassonomica

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h3 class="card-title">Dettaglio Validazione tassonomica</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">Descrizione</dt>
            <dd class="col-sm-10">@Model.descrizione</dd>
            <dt class="col-sm-2">Descrizione EN</dt>
            <dd class="col-sm-10">@Model.descrizione_en</dd>
            <dt class="col-sm-2">Ordinamento</dt>
            <dd class="col-sm-10">@Model.ordinamento</dd>
            <dt class="col-sm-2">Organizzazione</dt>
            <dd class="col-sm-10">@Model.organizzazioneNavigation?.descrizione</dd>
        </dl>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.id" class="btn btn-warning">Modifica</a>
    <a asp-action="Index" class="btn btn-info">Indietro</a>
</div>


