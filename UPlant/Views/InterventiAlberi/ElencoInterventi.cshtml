@model IEnumerable<UPlant.Models.DB.InterventiAlberi>
@inject LanguageService language

@{
    ViewBag.Title = language.Getkey("Global_Tree_Interventions");
    ViewBag.lang = language.GetCurrentCulture();
    var currentCulture = language.GetCurrentCulture();
}

<p>
    <a asp-action="Index" asp-controller="InterventiAlberi">
        <span class="btn btn btn-info " title="@language.Getkey("Global_Go_Back")">
            @language.Getkey("Global_Go_Back")
        </span>
    </a>
    @{
        @if (User.IsInRole("Administrator") ||  User.IsInRole("TreeManager"))
        {
            <a asp-action="Create" asp-controller="InterventiAlberi" asp-route-idindividuo="@ViewBag.idindividuo">
                <span class="btn btn-success" title="@language.Getkey("Global_Add") @language.Getkey("Global_Tree_Interventions")">
            @language.Getkey("Global_Add") @language.Getkey("Global_Tree_Interventions")
        </span>
    </a>
    }
    }
</p>

<div class="card  card-primary mt-3">

    <div class="card-header with-border">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <h3 class="card-title mb-0 mr-3  font-weight-bold">
                    @(ViewData["nomescientifico"] ?? "") - @(ViewData["progressivo"] ?? "")
                </h3>
                <a asp-action="Details"
                   asp-controller="Individui"
                   asp-route-id="@ViewBag.idindividuo"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn btn-outline-light btn-sm mr-2"
                   title="@language.Getkey("Global_Details") @language.Getkey("Global_Individual")">
                    @language.Getkey("Global_Details") @language.Getkey("Global_Individual")
                </a>
                <div id="table1HeaderLeft" class="d-flex align-items-center"></div>
            </div>
            <div id="table1HeaderRight" class="d-flex align-items-center"></div>
        </div>
    </div>

    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped table-sm">
            <thead>
                <tr>
                    <th>@language.Getkey("Global_Tree_Priority")</th>
                    <th>@language.Getkey("Global_Tree_Interventions")</th>
                    <th>@language.Getkey("Global_Reason")</th>
                    <th>@language.Getkey("Global_Last_Modified_Date")</th>
                    <th>@language.Getkey("Global_Intervention_Status")</th>
                    @{
                        @if (User.IsInRole("Administrator") ||  User.IsInRole("TreeManager"))
                        {
                            <th style="width:60px;"></th>
                        }
                     }
                        </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.statoIntervento ? "intervento-chiuso" : string.Empty)">
                        @if (currentCulture == "en-US")
                        {
                            <td class="text-center">
                                <span class="priority-chip" style="background-color:@item.prioritaNavigation.colore">
                                    @if (string.IsNullOrEmpty(item.prioritaNavigation.descrizione_en))
                                    {
                                        @Html.DisplayFor(model => item.prioritaNavigation.descrizione)
                                    }
                                    else
                                    {

                                        @Html.DisplayFor(model => item.prioritaNavigation.descrizione_en)
                                    }
                                </span>
                            </td>
                        }
                        else
                        {

                            <td class="text-center"><span class="priority-chip" style="background-color:@item.prioritaNavigation.colore">@item.prioritaNavigation.descrizione</span></td>
                        }
                        <td class="text-center">@item.interventoNavigation.descrizione</td>
                        <td class="text-center">@item.motivo</td>
                        <td class="text-center">@(item.dataultimamodifica?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td class="text-center">@(item.statoIntervento == false ? language.Getkey("Global_Open") : language.Getkey("Global_Close"))</td>
                          @{
                            @if (User.IsInRole("Administrator") || User.IsInRole("TreeManager"))
                            {
                        
                            <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.id" class="btn btn-warning btn-sm" title="@language.Getkey("Global_Edit")">
                                <i class="fa-solid fa-pencil" style="color: #fafafa;"></i>
                            </a>
                            </td>
                            }
                          }
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted mt-2">
                @language.Getkey("Global_NoResults")
            </div>
        }
    </div>
</div>

@section CustomStyles {
    <style>
        .priority-chip {
            display:inline-block;
            padding: 0.2rem 0.5rem;
            border-radius: 0.25rem;
            color: #fff;
            font-weight: 600;
        }

        #table1HeaderLeft label,
        #table1HeaderRight label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        #table1HeaderLeft select {
            width: 90px;
            display: inline-block;
            margin: 0 6px;
        }

        #table1HeaderRight input {
            width: 190px;
            display: inline-block;
            margin-left: 6px;
        }

        #table1HeaderLeft, #table1HeaderRight {
            gap: 10px;
        }


        #table1 tbody tr.intervento-chiuso {
            color: #6c757d;
            background-color: #f3f4f6;
                
        }

        #table1 tbody tr.intervento-chiuso td {
            opacity: 0.85;
        }

            #table1 tbody tr.intervento-chiuso .priority-chip {
                background-color: #c2c1bd !important;
                color: #ffffff !important;
        }
    </style>
}

@section Scripts {
    <script src="~/js/datatables.min.js"></script>
}

@section CustomScripts {
    <script>
        $(function () {
            var lingua = "@ViewBag.lang";
            if (lingua === "en-US") {
                $.extend($.fn.dataTable.defaults, {
                    language: { url: "/js/dataTables.english.json" }
                });
            } else {
                $.extend($.fn.dataTable.defaults, {
                    language: { url: "/js/dataTables.default.json" }
                });
            }

            var dt = $('#table1').DataTable({
                paging: true,
                lengthChange: true,
                searching: true,
                info: true,
                autoWidth: false,
                ordering: true
            });

            var wrapper = $('#table1').closest('.dataTables_wrapper');
            $('#table1HeaderLeft').empty().append(wrapper.find('#table1_length').detach());
            $('#table1HeaderRight').empty().append(wrapper.find('#table1_filter').detach());

        });
    </script>
}
