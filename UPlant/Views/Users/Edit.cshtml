@model UPlant.Models.DB.Users
@inject LanguageService language
@{
    ViewData["Title"] = "Edit";
    var ruoloItems = ((SelectList)ViewData["Ruolo"]).ToList();
    var administratorRole = ruoloItems.FirstOrDefault(r => string.Equals(r.Text, "Administrator", StringComparison.OrdinalIgnoreCase));
    var operatorRole = ruoloItems.FirstOrDefault(r => string.Equals(r.Text, "Operator", StringComparison.OrdinalIgnoreCase));
    var readerRole = ruoloItems.FirstOrDefault(r => string.Equals(r.Text, "Reader", StringComparison.OrdinalIgnoreCase));
    var discoverRole = ruoloItems.FirstOrDefault(r => string.Equals(r.Text, "Discover", StringComparison.OrdinalIgnoreCase));
    var treeManagerRole = ruoloItems.FirstOrDefault(r => string.Equals(r.Text, "TreeManager", StringComparison.OrdinalIgnoreCase));
    var selectedPrimaryRole = administratorRole?.Selected == true ? administratorRole : operatorRole?.Selected == true ? operatorRole : readerRole;
    var isOperatorSelected = operatorRole?.Selected == true;
}

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h3 class="card-title">@language.Getkey("Global_Edit") @language.Getkey("Global_User")</h3>
    </div>
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <b>@language.Getkey("Global_Name")</b>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <b>@language.Getkey("Global_Surname")</b>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="control-label">@language.Getkey("Global_Email")</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <b>@language.Getkey("Global_Username")</b>
                <input asp-for="UnipiUserName" class="form-control" />
                <span asp-validation-for="UnipiUserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <b> @language.Getkey("Global_Tax_Code")</b>
                <input asp-for="CF" class="form-control" />
                <span asp-validation-for="CF" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsEnabled" /> <b>@language.Getkey("Global_Enabled")</b>
                </label>
            </div>
           @*  <div class="form-group">
                <label asp-for="CreatedAt" class="control-label"></label>
                <input asp-for="CreatedAt" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedBy" class="control-label"></label>
                <input asp-for="CreatedBy" class="form-control" />
                <span asp-validation-for="CreatedBy" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedFrom" class="control-label"></label>
                <input asp-for="CreatedFrom" class="form-control" />
                <span asp-validation-for="CreatedFrom" class="text-danger"></span>
            </div>*@
            <div class="form-group">
                <label class="control-label">@language.Getkey("Global_Role")</label>
                <div class="mt-2">
                    @if (administratorRole != null)
                    {
                        <div class="form-check">
                            <input class="form-check-input js-primary-role" type="radio" name="ruoli" id="role-administrator" value="@administratorRole.Value" @(selectedPrimaryRole?.Value == administratorRole.Value ? "checked" : "") />
                            <label class="form-check-label" for="role-administrator">Administrator</label>
                        </div>
                    }
                    @if (operatorRole != null)
                    {
                        <div class="form-check">
                            <input class="form-check-input js-primary-role" type="radio" name="ruoli" id="role-operator" value="@operatorRole.Value" @(selectedPrimaryRole?.Value == operatorRole.Value ? "checked" : "") />
                            <label class="form-check-label" for="role-operator">Operator</label>
                        </div>
                    }
                    @if (readerRole != null)
                    {
                        <div class="form-check">
                            <input class="form-check-input js-primary-role" type="radio" name="ruoli" id="role-reader" value="@readerRole.Value" @(selectedPrimaryRole?.Value == readerRole.Value ? "checked" : "") />
                            <label class="form-check-label" for="role-reader">Reader</label>
                        </div>
                    }
                </div>
                <div class="mt-2 ms-3">
                    @if (discoverRole != null)
                    {
                        <div class="form-check">
                            <input class="form-check-input js-operator-extra" type="checkbox" name="ruoli" id="role-discover" value="@discoverRole.Value" @(discoverRole.Selected ? "checked" : "") @(!isOperatorSelected ? "disabled" : "") />
                            <label class="form-check-label" for="role-discover">Discover</label>
                        </div>
                    }
                    @if (treeManagerRole != null)
                    {
                        <div class="form-check">
                            <input class="form-check-input js-operator-extra" type="checkbox" name="ruoli" id="role-treemanager" value="@treeManagerRole.Value" @(treeManagerRole.Selected ? "checked" : "") @(!isOperatorSelected ? "disabled" : "") />
                            <label class="form-check-label" for="role-treemanager">TreeManager</label>
                        </div>
                    }
                </div>
                <small class="form-text text-muted">Administrator, Operator e Reader sono alternativi. Discover e TreeManager sono selezionabili solo con Operator.</small>
            </div>
            <div class="form-group">
                <label asp-for="TipologiaUtente" class="control-label">@language.Getkey("Global_User_Type")</label>
                <select asp-for="TipologiaUtente" class="form-control" asp-items="ViewBag.TipologiaUtente"></select>
                <span asp-validation-for="TipologiaUtente" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Organizzazione" class="control-label">@language.Getkey("Global_Organization")</label>
                <select asp-for="Organizzazione" class="form-control" asp-items="ViewBag.Organizzazione"></select>
                <span asp-validation-for="Organizzazione" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="@language.Getkey("Global_Save")" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary">@language.Getkey("Global_Go_Back")</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const operatorRadio = document.getElementById('role-operator');
            const primaryRoleRadios = document.querySelectorAll('.js-primary-role');
            const operatorExtras = document.querySelectorAll('.js-operator-extra');

            const toggleOperatorExtras = () => {
                const enableExtras = operatorRadio && operatorRadio.checked;

                operatorExtras.forEach(extra => {
                    extra.disabled = !enableExtras;
                    if (!enableExtras) {
                        extra.checked = false;
                    }
                });
            };

            primaryRoleRadios.forEach(radio => {
                radio.addEventListener('change', toggleOperatorExtras);
            });

            toggleOperatorExtras();
        })();
    </script>
}
