@using Azure.Core
@using System.Text.Json
@model IEnumerable<UPlant.Models.DB.RisultatoRicercaInd>
@inject LanguageService language

@{
    ViewBag.Title = @language.Getkey("Home_Index_7");
    ViewBag.lang = language.GetCurrentCulture();
    var currentCulture = language.GetCurrentCulture();
    var results = Model?.ToList() ?? new List<UPlant.Models.DB.RisultatoRicercaInd>();
    var hasSearched = ViewBag.hasSearched is bool searched && searched;
    var mapData = results
        .Select(item => new
        {
            lat = item.latitudine,
            lng = item.longitudine,
            progressivo = item.progressivo,
            nomeScientifico = item.nome_scientifico,
            settore = currentCulture == "en-US" ? item.settore_en : item.settore,
            collezione = currentCulture == "en-US" ? item.collezione_en : item.collezione,
            destinazioni = item.destinazioni,
            stato = currentCulture == "en-US" ? item.stato_en : item.stato,
            detailUrl = Url.Action("Details", "Individui", new { id = item.id, tipo = "ricerca" })
        })
        .ToList();
}

<div class="card card-primary mt-2">
    <div class="card-header" data-toggle="collapse" data-target="#ricercaCollapse" style="cursor:pointer;">
        <h3 class="card-title mb-0 font-weight-bold">@language.Getkey("Home_Index_7")</h3>
    </div>
    <div id="ricercaCollapse" class="collapse show">
        <div class="card-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "ricercaform" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <div class="form-row">
                    <div class="form-group col-md-4 autocomplete">
                        <label>@language.Getkey("Global_Scientific_Name")</label>
                        <input type="text" class="form-control" id="specie" name="specie" placeholder="@language.Getkey("Global_Scientific_Name")" value="@ViewBag.specie">
                    </div>
                    <div class="form-group col-md-4 autocomplete">
                        <label>@language.Getkey("Global_Accession_Progressive")</label>
                        <input type="text" id="progacc" name="progacc" class="form-control" value="@ViewBag.progacc" placeholder="@language.Getkey("Global_Accession_Progressive")">
                    </div>
                    <div class="form-group col-md-4 autocomplete">
                        <label>@language.Getkey("Global_Destinations")</label>
                        <input type="text" id="destinations" name="destinations" class="form-control" value="@ViewBag.destinations" placeholder="@language.Getkey("Global_Destinations")">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-xl-3 col-lg-4 col-md-6">
                        <label>@language.Getkey("Global_Family")</label>
                        @Html.DropDownList("famiglia", (IEnumerable<SelectListItem>)ViewBag.listafamiglie, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "famiglia", @class = "form-control" })
                    </div>
                    <div class="form-group col-xl-3 col-lg-4 col-md-6">
                        <label>@language.Getkey("Global_Sector")</label>
                        @Html.DropDownList("settore", (IEnumerable<SelectListItem>)ViewBag.listasettori, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "settore", @class = "form-control" })
                    </div>
                    <div class="form-group col-xl-3 col-lg-4 col-md-6">
                        <label>@language.Getkey("Global_Collection")</label>
                        @Html.DropDownList("collezione", (IEnumerable<SelectListItem>)ViewBag.listacollezioni, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "collezione", @class = "form-control" })
                    </div>
                    <div class="form-group col-xl-3 col-lg-6 col-md-6">
                        <label>@language.Getkey("Global_Propagation_Data")</label>
                        <div class="search-date-range">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">@language.Getkey("Global_From")</span>
                                </div>
                                <input id="datapropagazioneinizio" name="datapropagazioneinizio" class="form-control" type="date" value="@ViewBag.datapropagazioneinizio.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">@language.Getkey("Global_To")</span>
                                </div>
                                <input id="datapropagazionefine" name="datapropagazionefine" class="form-control" type="date" value="@ViewBag.datapropagazionefine.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-4">
                        <label>@language.Getkey("Global_Individual_Status")</label>
                        @Html.DropDownList("statoindividuo", (IEnumerable<SelectListItem>)ViewBag.listastatoindividui, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "statoindividuo", @class = "form-control" })
                    </div>
                    <div class="form-group col-md-4">
                        <label>@language.Getkey("Global_Condition")</label>
                        @Html.DropDownList("condizione", (IEnumerable<SelectListItem>)ViewBag.listacondizioni, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "condizione", @class = "form-control" })
                    </div>
                    <div class="form-group col-md-4">
                        <label>@language.Getkey("Global_Label")</label>
                        @Html.DropDownList("cartellino", (IEnumerable<SelectListItem>)ViewBag.listacartellini, @language.Getkey("Global_All"), htmlAttributes: new { @Id = "cartellino", @class = "form-control" })
                    </div>
                </div>
                <div class="d-flex align-items-center flex-wrap">
                    <input type="submit" value="@language.Getkey("Global_Search")" class="btn btn-success mr-2 mb-2" />
                    <input id="azzera" type="button" value="@language.Getkey("Global_Reset")" class="btn btn-danger mr-2 mb-2" />
                    @if ((User.IsInRole("Administrator") || User.IsInRole("Operator") || User.IsInRole("TreeKeeper") || User.IsInRole("Discover") || User.IsInRole("Seminum") || User.IsInRole("Utility")) && results.Count > 0)
                    {
                        <button type="button" class="btn btn-success mb-2" onclick="window.location.href = '@Url.Action("Download", "Home", new { file = ViewBag.filename })';">
                            @language.Getkey("Global_Download_Search_File") <span class="fa-solid fa-file-excel ml-1" aria-hidden="true"></span>
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="card card-primary mt-3" id="risultatoCard" style="display:none">
    <div class="card-header" data-toggle="collapse" data-target="#risultatiCollapse" style="cursor:pointer;">
        <h3 class="card-title mb-0 font-weight-bold">@language.Getkey("Global_Search_Results")</h3>
    </div>
    <div id="risultatiCollapse" class="collapse show">
        <div class="card-body">
            <div class="table-responsive">
                <table id="table1" class="table table-bordered table-striped dataTable search-results-table">
                    <thead>
                        <tr>
                            <th></th>
                            <th><span class="th-full">@language.Getkey("Global_Progressive")</span><span class="th-short">Prog.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Old_Progressive")</span><span class="th-short">Vec. prog.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Scientific_Name")</span><span class="th-short">Nome sci.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Sector")</span><span class="th-short">Sett.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Collection")</span><span class="th-short">Coll.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Destinations")</span><span class="th-short">Dest.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Individual_Status")</span><span class="th-short">Stato</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Label")</span><span class="th-short">Cart.</span></th>
                            <th><span class="th-full">@language.Getkey("Home_Ricerca_Individui_1")</span><span class="th-short">Nom.</span></th>
                            <th><span class="th-full">@language.Getkey("Global_Last_Modified_Date")</span><span class="th-short">Data mod.</span></th>
                            <th><span class="th-full">Data per formato yyymmmdd</span><span class="th-short">Data sort</span></th>
                            <th style="width:5%"><span class="th-full">@language.Getkey("Global_Number_Of_Images")</span><span class="th-short">Img</span></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in results)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-controller="Individui" asp-route-id="@item.id" asp-route-tipo="ricerca">
                                        <span class="btn btn-primary btn-xs" title="@language.Getkey("Global_Detail") @language.Getkey("Global_Individual")">
                                            <i class="fa-solid fa-search"></i>
                                        </span>
                                    </a>
                                    @if (User.IsInRole("Administrator") || User.IsInRole("Operator") || User.IsInRole("TreeKeeper") || User.IsInRole("Discover") || User.IsInRole("Seminum") || User.IsInRole("Utility"))
                                    {
                                        <button class="btn btn-info btn-xs" title="stampa etichetta" id="etichetta" onclick="stampa('@item.id','@item.nomeetichetta','@item.ipen','@item.shortprog')">
                                            <i class="fa-solid fa-print"></i>
                                        </button>
                                    }
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.progressivo)</td>
                                <td>@Html.DisplayFor(modelItem => item.vecchioprogressivo)</td>
                                <td>@Html.DisplayFor(modelItem => item.nome_scientifico)</td>
                                @if (currentCulture == "en-US")
                                {
                                    <td>@Html.DisplayFor(modelItem => item.settore_en)</td>
                                    <td>@Html.DisplayFor(modelItem => item.collezione_en)</td>
                                    <td>@Html.DisplayFor(modelItem => item.destinazioni)</td>
                                    <td>@Html.DisplayFor(modelItem => item.stato_en)</td>
                                    <td>@Html.DisplayFor(modelItem => item.cartellino_en)</td>
                                }
                                else
                                {
                                    <td>@Html.DisplayFor(modelItem => item.settore)</td>
                                    <td>@Html.DisplayFor(modelItem => item.collezione)</td>
                                    <td>@Html.DisplayFor(modelItem => item.destinazioni)</td>
                                    <td>@Html.DisplayFor(modelItem => item.stato)</td>
                                    <td>@Html.DisplayFor(modelItem => item.cartellino)</td>
                                }
                                <td>@Html.DisplayFor(modelItem => item.nomecognome)</td>
                                <td>@Convert.ToDateTime(item.datainserimento).ToString("dd/MM/yyyy")</td>
                                <td>@Convert.ToDateTime(item.datainserimento).ToString("yyyyMMdd")</td>
                                <td>@Html.DisplayFor(modelItem => item.countimg)</td>
                                <td>
                                    @if (User.IsInRole("Administrator") || User.IsInRole("Operator") || User.IsInRole("TreeKeeper") || User.IsInRole("Discover") || User.IsInRole("Seminum") || User.IsInRole("Utility"))
                                    {
                                        <a asp-action="Edit" asp-controller="Individui" asp-route-id="@item.id" asp-route-tipo="ricerca">
                                            <span class="btn btn-warning btn-xs" title="@language.Getkey("Global_Edit") individuo">
                                                <i class="fa-solid fa-pencil" style="color: #fafafa;"></i>
                                            </span>
                                        </a>
                                    }
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <a asp-action="Delete" asp-controller="Individui" asp-route-id="@item.id" asp-route-tipo="ricerca">
                                            <span class="btn btn-danger btn-xs" title="@language.Getkey("Global_Delete") @language.Getkey("Global_Individual")">
                                                <i class="fa-solid fa-trash"></i>
                                            </span>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card card-primary mt-3" id="mappaCard" style="display:none">
    <div class="card-header" data-toggle="collapse" data-target="#mappaCollapse" style="cursor:pointer;">
        <h3 class="card-title mb-0 font-weight-bold">@language.Getkey("Global_Map")</h3>
    </div>
    <div id="mappaCollapse" class="collapse show">
        <div class="card-body">
            <div id="ricercaIndividuiMap" style="width:100%; min-height:420px;"></div>
            <div id="ricercaIndividuiMapEmpty" class="alert alert-info d-none mb-0">@language.Getkey("Global_Coordinates_Not_Available")</div>
        </div>
    </div>
</div>

<div class="modal fade bd-example-modal" data-backdrop="static" data-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content" style="top: 350px;right: 100px; bottom: 0;  left: 0; z-index: 10040; ">
            <img src="~/img/loading.gif" />
        </div>
    </div>
</div>

<div class="row" id="gifricerca">
    <div class="col-md-12 center">
        <table id="table2" class="table table-bordered dataTable">
            <thead></thead>
            <tbody>
                <tr><td style="text-align: center; vertical-align: middle;"><img src="~/img/load.gif" /> .. Ricerca in Corso ..</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/datatables.min.css" rel="stylesheet" />
}

@section CustomStyles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <style>
        .individual-map-marker-wrapper {
            background: transparent;
            border: 0;
        }

        .individual-map-pin {
            display: inline-block;
            width: 16px;
            height: 16px;
            border-radius: 50% 50% 50% 0;
            border: 2px solid #ffffff;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
            transform: rotate(-45deg);
            background-color: #2b7de9;
        }

        .search-date-range {
            display: flex;
            gap: 0.5rem;
            align-items: stretch;
        }

        .search-date-range .input-group {
            flex: 1 1 0;
            min-width: 0;
        }

        .th-short {
            display: none;
        }

        .search-results-table {
            width: 100% !important;
        }

        @@media (max-width: 1440px) {
            .search-results-table {
                font-size: 0.92rem;
            }

            .search-results-table th,
            .search-results-table td {
                padding: 0.45rem;
            }

            .th-full {
                display: none;
            }

            .th-short {
                display: inline;
            }
        }

        @@media (max-width: 991.98px) {
            .search-date-range {
                display: block;
            }

            .search-date-range .input-group + .input-group {
                margin-top: 0.5rem;
            }
        }
    </style>
}

@section Scripts {
    <script src="~/js/select2.min.js"></script>
    <script src="~/js/datatables.min.js"></script>
    <script src="~/js/dymo.connect.framework.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
}

@section CustomScripts {
    <script type="text/javascript">
        $(document).ready(function () {
            $('#gifricerca').hide();

            if (@(hasSearched.ToString().ToLower())) {
                $('#risultatoCard').show();
                $('#mappaCard').show();
            }

            $('#ricercaform').submit(function () {
                $('#risultatoCard').hide();
                $('#mappaCard').hide();
                $('#gifricerca').show();
            });

            var lingua = "@ViewBag.lang";
            if (lingua == "en-US") {
                $.extend($.fn.dataTable.defaults, { language: { url: "/js/dataTables.english.json" } });
            } else {
                $.extend($.fn.dataTable.defaults, { language: { url: "/js/dataTables.default.json" } });
            }

            var rawData = @Html.Raw(JsonSerializer.Serialize(mapData));
            var markersData = (rawData || []).map(function (entry) {
                var lat = Number(String(entry.lat || '').replace(',', '.'));
                var lng = Number(String(entry.lng || '').replace(',', '.'));
                if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                    return null;
                }
                return {
                    lat: lat,
                    lng: lng,
                    progressivo: entry.progressivo,
                    nomeScientifico: entry.nomeScientifico,
                    settore: entry.settore,
                    collezione: entry.collezione,
                    destinazioni: entry.destinazioni,
                    stato: entry.stato,
                    detailUrl: entry.detailUrl
                };
            }).filter(function (x) { return x !== null; });

            if (@(hasSearched.ToString().ToLower())) {
                if (markersData.length === 0) {
                    $('#ricercaIndividuiMap').addClass('d-none');
                    $('#ricercaIndividuiMapEmpty').removeClass('d-none');
                } else {
                    function addFullscreenMapControl(map) {
                        var FullscreenControl = L.Control.extend({
                            options: { position: 'topright' },
                            onAdd: function () {
                                var container = L.DomUtil.create('div', 'leaflet-bar');
                                var button = L.DomUtil.create('a', '', container);
                                button.href = '#';
                                button.title = 'Schermo intero';
                                button.setAttribute('role', 'button');
                                button.innerHTML = '&#x26F6;';
                                button.style.fontSize = '18px';
                                button.style.lineHeight = '28px';
                                button.style.textAlign = 'center';

                                L.DomEvent.on(button, 'click', function (e) {
                                    L.DomEvent.stop(e);
                                    var mapElement = map.getContainer();
                                    if (!document.fullscreenElement) {
                                        mapElement.requestFullscreen();
                                    } else {
                                        document.exitFullscreen();
                                    }
                                });

                                return container;
                            }
                        });

                        map.addControl(new FullscreenControl());
                        if (!map._fullscreenChangeBound) {
                            document.addEventListener('fullscreenchange', function () { map.invalidateSize(); });
                            map._fullscreenChangeBound = true;
                        }
                    }

                    var map = L.map('ricercaIndividuiMap', { scrollWheelZoom: false });
                    map.attributionControl.setPrefix(false);
                    map.attributionControl.setPosition('bottomleft');
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        maxZoom: 20,
                        attribution: '&copy; OpenStreetMap contributors'
                    }).addTo(map);

                    addFullscreenMapControl(map);

                    var bounds = [];
                    markersData.forEach(function (item) {
                        var markerIcon = L.divIcon({
                            className: 'individual-map-marker-wrapper',
                            html: '<span class="individual-map-pin"></span>',
                            iconSize: [20, 20],
                            iconAnchor: [10, 20],
                            popupAnchor: [0, -20]
                        });

                        var marker = L.marker([item.lat, item.lng], { icon: markerIcon }).addTo(map);
                        marker.bindPopup(
                            '<div><strong>' + (item.progressivo || '-') + '</strong></div>' +
                            '<div>' + (item.nomeScientifico || '-') + '</div>' +
                            '<div>Settore: ' + (item.settore || '-') + '</div>' +
                            '<div>Collezione: ' + (item.collezione || '-') + '</div>' +
                            '<div>Destinazione: ' + (item.destinazioni || '-') + '</div>' +
                            '<div>Stato: ' + (item.stato || '-') + '</div>' +
                            '<div class="mt-1"><a href="' + item.detailUrl + '" target="_blank" rel="noopener noreferrer">Dettaglio individuo</a></div>'
                        );
                        bounds.push([item.lat, item.lng]);
                    });

                    map.fitBounds(bounds, { padding: [30, 30] });

                    $('#mappaCollapse').on('shown.bs.collapse', function () {
                        setTimeout(function () { map.invalidateSize(); }, 180);
                    });
                }
            }
        });
    </script>

    <script>
        jQuery(function () {
            jQuery('#table1').DataTable({
                'paging': true,
                'lengthChange': true,
                'searching': true,
                'ordering': true,
                'info': true,
                'scrollX': true,
                'autoWidth': false,
                "columnDefs": [
                    { "orderData": [11], "targets": [10] },
                    {
                        'targets': [11],
                        'visible': false,
                        'searchable': false
                    }
                ]
            })
        })
    </script>

    <script>
        $("#famiglia").select2({});
        $("#settore").select2({});
        $("#collezione").select2({});
        $("#statoindividuo").select2({});
        $("#condizione").select2({});
        $("#cartellino").select2({});

        $(document).ready(function () {
            var codsettoresel = $('#settore :selected').val();
            if (codsettoresel != '') {
                var viewbagcol = "@ViewBag.collezione";
                var all = "@language.Getkey("Global_All")";
                $("#collezione").removeAttr("disabled");
                $.ajax({
                    type: "GET",
                    url: baseUrlCollezioni,
                    data: {
                        'codicesettore': codsettoresel
                    },
                    success: function (data) {
                        var s = '<option value="">' + all + '</option>';
                        for (var i = 0; i < data.length; i++) {
                            if (viewbagcol == data[i].codicecollezione) {
                                s += '<option value="' + data[i].codicecollezione + '" selected="selected">' + data[i].descrizionecollezione + '</option>';
                            } else {
                                s += '<option value="' + data[i].codicecollezione + '">' + data[i].descrizionecollezione + '</option>';
                            }
                        }
                        if (i == 0) {
                            alert("Il settore non ha collezioni corrispondenti verificare e correggi");
                            $('#settore').focusin();
                        }
                        $("#collezione").html(s);
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        alert('Error during process: \n' + xhr.responseText);
                    }
                });

                var objSelect = document.getElementById("collezione");
                setSelectedValue(objSelect, viewbagcol);
            } else {
                $('#collezione').val('').trigger('change');
                $('#collezione').prop('disabled', true);
            }
        });
    </script>

    <script>
        var baseUrlCercaspecie = '@Url.Action("Cercaspecie", "Common")';
        $("#specie").autocomplete({
            source: baseUrlCercaspecie,
            minLength: 3,
            position: { offset: '-30 0' }
        });
    </script>

    <script>
        var baseUrlCercaprog = '@Url.Action("Cercaprog", "Common")';
        $("#progacc").autocomplete({
            source: baseUrlCercaprog,
            minLength: 3,
            position: { offset: '-30 0' }
        });
    </script>

    <script>
        var baseUrlCercadest = '@Url.Action("Cercadest", "Common")';
        $("#destinations").autocomplete({
            source: baseUrlCercadest,
            minLength: 3,
            position: { offset: '-30 0' }
        });
    </script>

    <script>
        var baseUrlSettori = '@Url.Action("GetSettori", "Common")';
        var baseUrlCollezioni = '@Url.Action("GetCollezioni", "Common")';

        $('#settore').on("change", function () {
            var codsettoresel = $('#settore :selected').val();
            var all = "@language.Getkey("Global_All")";
            if (codsettoresel != '') {
                $('#collezione').val('').trigger('change');
                $("#collezione").removeAttr("disabled");
                $.ajax({
                    type: "GET",
                    url: baseUrlCollezioni,
                    data: {
                        'codicesettore': codsettoresel
                    },
                    success: function (data) {
                        var s = '<option value="">' + all + '</option>';
                        for (var i = 0; i < data.length; i++) {
                            s += '<option value="' + data[i].codicecollezione + '">' + data[i].descrizionecollezione + '</option>';
                        }
                        if (i == 0) {
                            alert("Il settore non ha collezioni corrispondenti verificare e correggi");
                            $('#settore').focusin();
                        }
                        $("#collezione").html(s);
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        alert('Error during process: \n' + xhr.responseText);
                    }
                });
            } else {
                $('#collezione').val('').trigger('change');
