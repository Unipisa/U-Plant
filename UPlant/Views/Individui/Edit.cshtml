@model UPlant.Models.DB.Individui
@inject LanguageService language
@inject Microsoft.Extensions.Options.IOptions<UPlant.Models.AppSettings> AppSettings
@{
    ViewData["Title"] = "Edit";
}

 <form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
   
<div class="col-lg-12">
        <div class="form-group">


            @Html.ActionLink(@language.Getkey("Global_Go_Back"), null, null, null, new { @class = "btn btn-info go_back" })
                    



           
            <span> </span>
            @Html.ActionLink(@language.Getkey("Global_Return_To_Parent_Accession"), "Details", "Accessioni", new { id = Model.accessione }, new { @class = "btn btn-warning" })
           
            
            

        </div>
        
    <div class="card card-outline card-primary">
        <div class="card-header with-border">
                <h3 class="card-title font-weight-bold"> <span class="text-primary">@language.Getkey("Global_Edit")</span> - @Html.DisplayFor(model => model.progressivo) - @Html.DisplayFor(model => model.accessioneNavigation.specieNavigation.nome_scientifico) </h3>
                
        </div>

       <div class="card-body">
                <div class="form-group">
                    @Html.HiddenFor(model => model.id)
                    @Html.Hidden("id", null, new { @id = "id" })
                    @Html.Hidden("idindividuo", null, new { @id = "idindividuo" })
                    @Html.Hidden("progressivo", null, new { @id = "progressivo" })
                    @Html.Hidden("tipo", null, new { @id =  ViewBag.tipo })
               
                </div>
                <div class="row">
                    <div class="form-group col">
                        <label asp-for="propagatoData" class="control-label">@language.Getkey("Global_Propagation_Data")</label>
                        <input asp-for="propagatoData" class="form-control" />
                        <span asp-validation-for="propagatoData" class="text-danger"></span>
                    </div>

                    <div class="form-group col">
                        <label asp-for="propagatoModalita" class="control-label"> @language.Getkey("Global_Propagation_Method")</label>
                        <select asp-for="propagatoModalita" class="form-control" asp-items="ViewBag.propagatoModalita"></select>
                        <span asp-validation-for="propagatoModalita" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="sesso" class="control-label">@language.Getkey("Global_Sex")</label>
                        <select asp-for="sesso" class="form-control" asp-items="ViewBag.sesso"></select>
                        <span asp-validation-for="sesso" class="text-danger"></span>
                    </div>


                    <div class="form-group col">
                        <label asp-for="vecchioprogressivo" class="control-label">@language.Getkey("Global_Old_Progressive")</label>
                        <input asp-for="vecchioprogressivo" class="form-control" />
                        <span asp-validation-for="vecchioprogressivo" class="text-danger"></span>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="form-group col font-weight-bold"> @language.Getkey("Global_Location_Garden")</div>
                </div>
                <hr>
                <div class="row"> 

                    <div class="form-group col">
                        <label asp-for="settore" class="control-label">@language.Getkey("Global_Sector")</label>
                        <select asp-for="settore" class="form-control" asp-items="ViewBag.settore"></select>
                        <span asp-validation-for="settore" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="collezione" class="control-label">@language.Getkey("Global_Collection")</label>
                        <select asp-for="collezione" class="form-control" asp-items="ViewBag.collezione"></select>
                        <span asp-validation-for="collezione" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="cartellino" class="control-label">@language.Getkey("Global_Label")</label>
                        <select asp-for="cartellino" class="form-control" asp-items="ViewBag.cartellino"></select>
                        <span asp-validation-for="cartellino" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="longitudine" class="control-label">@language.Getkey("Global_Longitude")</label>
                        <input asp-for="longitudine" class="form-control" id="longitudine" name="longitudine" />
                        <span asp-validation-for="longitudine" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="latitudine" class="control-label">@language.Getkey("Global_Latitude")</label>
                        <input asp-for="latitudine" class="form-control" id="latitudine" name="latitudine" />
                        <span asp-validation-for="latitudine" class="text-danger"></span>
                    </div>
                </div>

                <hr>
                <div class="row">
                    <div class="form-group col" id="myMap" align="center"></div>
                </div>
                <hr>
                <div class="row">
                    <div class="form-group col">
                        <label asp-for="destinazioni" class="control-label">@language.Getkey("Global_Destinations")</label>
                        <input asp-for="destinazioni" class="form-control" id="destinazioni" name="destinazioni" />
                        <span asp-validation-for="destinazioni" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="indexSeminum" class="control-label">Index Seminum</label><br />
                        <input asp-for="indexSeminum" class="form-check-input"  id="indexSeminum" name="indexSeminum" />
                        <span asp-validation-for="indexSeminum" class="text-danger"></span>
                    </div>

                    <div class="form-group col">
                        <label asp-for="note" class="control-label">@language.Getkey("Global_Notes")</label>
                        <input asp-for="note" class="form-control" id="note" name="note" />
                        <span asp-validation-for="note" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        @Html.Label("")
                        @Html.Hidden(" ", "", new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.note, "", new { @class = "text-danger" })
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="form-group col font-weight-bold"> @language.Getkey("Global_Current_Situation")</div>
                </div>
                <hr>
                <div class="row">
                <div class="form-group col">
                        @Html.Label(@language.Getkey("Global_Condition"))<br />
                        @ViewBag.condizione
                        @*Html.DisplayFor(model => model.StoricoIndividuo.ToList().Last().condizioneNavigation.condizione)*@
                </div>
                <div class="form-group col">
                        @Html.Label(@language.Getkey("Global_Individual_Status"))<br />
                        @ViewBag.statoindividuo
                        @* @Html.DisplayFor(model => model.StoricoIndividuo.ToList().Last().statoIndividuoNavigation.stato)*@
                </div>
                <div class="form-group col">
                        @Html.Label(@language.Getkey("Global_Horticultural_Operations"))<br />
                    @Html.DisplayFor(model => model.StoricoIndividuo.ToList().Last().operazioniColturali)
                </div>
                </div>
                <hr>
                <div class="row">
                    <div class="form-group col">
                        <input type="submit" value="@language.Getkey("Global_Save")" class="btn btn-success" />
                    </div>
                </div>
       </div>

            
    </div>

        <div class="form-group">

            @Html.ActionLink(@language.Getkey("Global_Go_Back"), null, null, null, new { @class = "btn btn-info go_back" })
            <span> </span>
            @Html.ActionLink(@language.Getkey("Global_Return_To_Parent_Accession"), "Details", "Accessioni", new { id = Model.accessione }, new { @class = "btn btn-warning" })




        </div>
    
</div>
    
</form>
@section Styles {
    <link href="~/css/select2.min.css" rel="stylesheet" />


}
@section CustomStyles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <style>
        #myMap {
            height: 250px;
            width: 100%;
        }


        .zoom {
            padding: 0px;
            transition: transform .2s; /* Animation */
            width: 50px;
            height: 50px;
            margin: 0 auto;
        }

            .zoom:hover {
                transform: scale(6.5); /* (150% zoom - Note: if the zoom is too large, it will go outside of the viewport) */
            }

        .map-priority-marker-wrapper {
            background: transparent;
            border: none;
        }

        .map-priority-pin {
            display: inline-block;
            width: 16px;
            height: 16px;
            border-radius: 50% 50% 50% 0;
            border: 2px solid #ffffff;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
            transform: rotate(-45deg);
        }
    </style>
}
@section Scripts {


    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="~/js/select2.min.js"></script>
    <script src="~/js/jquery.validation.min.js"></script>
    <script src="~/js/scriptIndividui.js"></script>





}
@section CustomScripts {

    <script type="text/javascript">
        const defaultLat = @AppSettings.Value.Maps.DefaultLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const defaultLng = @AppSettings.Value.Maps.DefaultLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const latInput = $('#latitudine').val();
        const lngInput = $('#longitudine').val();
        const startLat = latInput ? parseFloat(latInput) : defaultLat;
        const startLng = lngInput ? parseFloat(lngInput) : defaultLng;

        const map = L.map('myMap').setView([startLat, startLng], 18);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 20,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        function getSelectedSettoreColor() {
            var selectedSettore = $('#settore').val();
            if (!selectedSettore || !window.settoriColorMap) {
                return '#6c757d';
            }

            return settoriColorMap[selectedSettore] || '#6c757d';
        }

        function buildColoredMarkerIcon(color) {
            return L.divIcon({
                className: 'map-priority-marker-wrapper',
                html: '<span class="map-priority-pin" style="background-color:' + color + ';"></span>',
                iconSize: [20, 20],
                iconAnchor: [10, 20]
            });
        }

        const marker = L.marker([startLat, startLng], {
            draggable: true,
            icon: buildColoredMarkerIcon(getSelectedSettoreColor())
        }).addTo(map);

        function updateCoordinates(latlng) {
            $('#latitudine').val(latlng.lat.toFixed(8));
            $('#longitudine').val(latlng.lng.toFixed(8));
        }

        map.on('click', function (event) {
            marker.setLatLng(event.latlng);
            updateCoordinates(event.latlng);
        });

        marker.on('dragend', function () {
            updateCoordinates(marker.getLatLng());
        });
    </script>

    <script>
       // $('#collezione').prop('disabled', true);// aggiunta altrimenti si poteva selezionare una collezione senza aver selezionato prima un settore
        var baseUrlSettori = '@Url.Action("GetSettori", "Common")';
        var baseUrlCollezioni = '@Url.Action("GetCollezioni", "Common")';
        var settoriColorMap = {};

        $.getJSON(baseUrlSettori, function (settori) {
            (settori || []).forEach(function (item) {
                settoriColorMap[item.codicesettore] = item.coloresettore || '#6c757d';
            });

            marker.setIcon(buildColoredMarkerIcon(getSelectedSettoreColor()));
        });

        $('#settore').on('change', function () {
            marker.setIcon(buildColoredMarkerIcon(getSelectedSettoreColor()));
        });
    </script>
    <script type="text/javascript">
        $(function () {
            $('.go_back').click(function (e) {
                e.preventDefault();
                history.go(-1);
            });
        });
    </script>



}