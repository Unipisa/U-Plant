@model List<UPlant.Models.DB.InterventiAlberi>
@inject LanguageService language
@using System.Text.Json

@{
    ViewBag.Title = language.Getkey("Global_Tree");
    ViewBag.lang = language.GetCurrentCulture();
    var currentCulture = language.GetCurrentCulture();
    var canManageTreeInterventions = User.IsInRole("Administrator") || (User.IsInRole("Operator") && User.IsInRole("TreeManager"));
    var openInterventiMapData = Model
        .Where(item => !item.statoIntervento && item.individuoNavigation != null)
        .Select(item => new
        {
            lat = item.individuoNavigation.latitudine,
            lng = item.individuoNavigation.longitudine,
            progressivo = item.individuoNavigation.progressivo,
            specie = item.individuoNavigation.accessioneNavigation?.specieNavigation?.nome_scientifico,
            settore = item.individuoNavigation.collezioneNavigation?.settoreNavigation?.settore,
            collezione = item.individuoNavigation.collezioneNavigation?.collezione,
            priorita = currentCulture == "en-US"
                ? (string.IsNullOrEmpty(item.prioritaNavigation?.descrizione_en)
                    ? item.prioritaNavigation?.descrizione
                    : item.prioritaNavigation?.descrizione_en)
                : item.prioritaNavigation?.descrizione,
            prioritaColore = item.prioritaNavigation?.colore,
            detailUrl = Url.Action("ElencoInterventi", "InterventiAlberi", new { id = item.individuo })
        })
        .ToList();
}

<h4 class="box-title">@language.Getkey("Shared_Comp_Sb_Tree")</h4>

<div class="d-flex align-items-center justify-content-between mb-2">
    @{
     @if (canManageTreeInterventions)
      {
     <button class="btn btn-primary btn-sm"
            type="button"
            id="btnToggleAggiungi"
            data-toggle="collapse"
            data-target="#addIndividuoCollapse"
            aria-expanded="false"
            aria-controls="addIndividuoCollapse">
        <i class="fa-solid fa-plus"></i> Aggiungi
        </button>
        }

        }
    

    <a asp-action="ExportTotaleInterventi"
       asp-controller="InterventiAlberi"
       class="btn btn-success btn-sm"
       title="Estrazione totale interventi alberi">
        <i class="fa-solid fa-file-excel"></i> Estrazione totale interventi
    </a>
</div>

@if (canManageTreeInterventions)
{
<div class="collapse" id="addIndividuoCollapse">
    <div class="card card-outline card-primary mt-2">
        <div class="card-body">

            <h4 class="box-title">@language.Getkey("Global_Add") @language.Getkey("Global_Individual")</h4>

            <div class="row align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@language.Getkey("Global_Scientific_Name")</label>
                    <input id="nomescientifico" name="nomescientifico" class="form-control" type="text"
                           placeholder="@language.Getkey("Global_Scientific_Name")">
                </div>
                <div class="col-md-2">
                    <button type="button" id="cerca" class="btn btn-success">
                        @language.Getkey("Global_Search")
                    </button>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-12">
                    <div id="risultato2" class="card  card-info d-none">
                        <div class="card-header  with-border">
                            <h5 class="card-title mb-0 font-weight-bold">@language.Getkey("Global_Search_Results")</h5>
                        </div>
                        <div class="card-body">
                            <div id="risultato2Content"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
}

<div class="card card-primary mt-3">

    <div class="card-header with-border">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <h3 class="card-title mb-0 mr-3 font-weight-bold">@language.Getkey("Global_List_Interventions")</h3>
                <div id="table1HeaderLeft" class="d-flex align-items-center"></div>
            </div>
            <div id="table1HeaderRight" class="d-flex align-items-center"></div>
        </div>
    </div>

    <div class="card-body">
        <table id="table1" class="table table-bordered table-striped table-sm">
            <thead>
                <tr>
                    <th style="width:60px;"></th>
                    <th>@language.Getkey("Global_Progressive")</th>
                    <th>@language.Getkey("Global_Scientific_Name")</th>
                    <th>@language.Getkey("Global_Sector")</th>
                    <th>@language.Getkey("Global_Collection")</th>
                    <th>@language.Getkey("Global_Tree_Priority")</th>
                    <th>@language.Getkey("Global_Last_Modified_Date")</th>
                    <th>Stato</th>
                    @{
                        @if (canManageTreeInterventions)
                        {
                            <th></th>
                        }
                    
                    }
                        </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // ordinamenti numerici per DataTables:
                    var isOpenOrder = (!item.statoIntervento) ? 1 : 0; // aperto=1, chiuso=0 (così DESC mette aperti prima)
                    var livello = item.prioritaNavigation?.livello ?? 0; // 4 urgente ... 0 nd
                    var dataIso = item.dataultimamodifica?.ToString("yyyy-MM-dd HH:mm:ss") ?? "0000-00-00 00:00:00";
                    var dataHuman = item.dataultimamodifica?.ToString("dd/MM/yyyy HH:mm") ?? "-";

                    <tr class="@(item.statoIntervento ? "intervento-chiuso" : string.Empty)">
                        <td class="text-center">
                            <a asp-action="ElencoInterventi"
                               asp-controller="InterventiAlberi"
                               asp-route-id="@item.individuo"
                               class="btn btn-primary btn-sm"
                               title="@($"{language.Getkey("Global_Detail")} {language.Getkey("Global_Individual")}")">
                                <i class="fa-solid fa-search"></i>
                            </a>
                        </td>

                        <td class="text-center">@item.individuoNavigation.progressivo</td>
                        <td class="text-center">@item.individuoNavigation.accessioneNavigation.specieNavigation.nome_scientifico</td>
                        <td class="text-center">@item.individuoNavigation.collezioneNavigation.settoreNavigation.settore</td>
                        <td class="text-center">@item.individuoNavigation.collezioneNavigation.collezione</td>

                        @* PRIORITÀ: data-order = livello numerico *@
                        @if (currentCulture == "en-US")
                        {
                            <td class="text-center" data-order="@livello">
                                <span class="priority-chip" style="background-color:@item.prioritaNavigation.colore">
                                    @if (string.IsNullOrEmpty(item.prioritaNavigation.descrizione_en))
                                    {
                                        @Html.DisplayFor(model => item.prioritaNavigation.descrizione)
                                    }
                                    else
                                    {
                                        @Html.DisplayFor(model => item.prioritaNavigation.descrizione_en)
                                    }
                                </span>
                            </td>
                        }
                        else
                        {
                            <td class="text-center" data-order="@livello">
                                <span class="priority-chip" style="background-color:@item.prioritaNavigation.colore">
                                    @item.prioritaNavigation.descrizione
                                </span>
                            </td>
                        }

                        @* DATA: data-order ISO per sort corretto *@
                        <td class="text-center" data-order="@dataIso">@dataHuman</td>

                        @* STATO: data-order numerico *@
                        <td class="text-center" data-order="@isOpenOrder">
                            @(!item.statoIntervento ? language.Getkey("Global_Open") : language.Getkey("Global_Close"))
                        </td>
                        @{
                            @if (canManageTreeInterventions)
                            {
                                <td class="text-center">
                                    <a asp-action="Create"
                                    asp-controller="InterventiAlberi"
                                    asp-route-idindividuo="@item.individuo"
                                    class="btn btn-primary btn-sm"
                                    title="@($"{language.Getkey("Global_Add")} {language.Getkey("Global_Individual")}")">
                                        <i class="fa-solid fa-plus"></i>
                                    </a>
                                </td>
                            }
                        }
                            </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center text-muted mt-2">
                @language.Getkey("Global_NoResults")
            </div>
        }
    </div>
</div>

<div class="card card-primary mt-3">
    <div class="card-header with-border">
        <h3 class="card-title mb-0 font-weight-bold">Mappa interventi aperti</h3>
    </div>
    <div class="card-body">
        <div id="openInterventiMap" class="open-interventi-map"></div>
        <div id="openInterventiMapEmpty" class="alert alert-info mb-0 d-none">
            Nessuna coordinata disponibile per gli interventi aperti.
        </div>
    </div>
</div>

@section CustomStyles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <style>
        .open-interventi-map {
            width: 100%;
            min-height: 420px;
            border-radius: 0.25rem;
        }


        .map-priority-marker-wrapper {
            background: transparent;
            border: 0;
        }

        .map-priority-pin {
            display: inline-block;
            width: 16px;
            height: 16px;
            border-radius: 50% 50% 50% 0;
            border: 2px solid #ffffff;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
            transform: rotate(-45deg);
        }

        .priority-chip {
            display: inline-block;
            padding: 0.2rem 0.5rem;
            border-radius: 0.25rem;
            color: #fff;
            font-weight: 600;
        }

        .ui-autocomplete {
            margin: 0px;
            font-family: Arial, Verdana, Sans-Serif;
            float: left;
            width: 10%;
            list-style-type: none;
            color: #0060B6;
            text-decoration: none;
        }

            .ui-autocomplete .fixed-height {
                float: left;
                max-height: 175px;
                overflow: auto !important;
                list-style-type: none;
            }

                .ui-autocomplete .fixed-height li {
                    font-family: Arial, Verdana, Sans-Serif;
                    float: left;
                    width: 100%;
                    text-align: left;
                    font: bold 26px Poiret One;
                }

            .ui-autocomplete .ui-menu-item .ui-corner-all {
                float: left;
                width: 100%;
                height: 30px;
                padding: 10px 0;
                background: #FFF;
            }

            .ui-autocomplete .ui-menu-item .ui-state-focus {
                background-color: #00F;
                cursor: pointer;
            }

        #table1HeaderLeft label,
        #table1HeaderRight label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        #table1HeaderLeft select {
            width: 90px;
            display: inline-block;
            margin: 0 6px;
        }

        #table1HeaderRight input {
            width: 190px;
            display: inline-block;
            margin-left: 6px;
        }

        #table1HeaderLeft, #table1HeaderRight {
            gap: 10px;
        }

        #table1 tbody tr.intervento-chiuso {
            color: #6c757d;
            background-color: #f3f4f6;
        }

            #table1 tbody tr.intervento-chiuso td {
                opacity: 0.85;
            }

            #table1 tbody tr.intervento-chiuso .priority-chip {
                background-color: #c2c1bd !important;
                color: #ffffff !important;
            }
    </style>
}

@section Scripts {
    <script src="~/js/datatables.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
}

@section CustomScripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var openInterventiRawData = @Html.Raw(JsonSerializer.Serialize(openInterventiMapData));

            function parseCoordinate(value) {
                if (value === null || value === undefined) {
                    return null;
                }

                var normalized = String(value).trim().replace(',', '.');
                if (!normalized) {
                    return null;
                }

                var parsed = Number(normalized);
                return Number.isFinite(parsed) ? parsed : null;
            }

            function initializeOpenInterventiMap() {
                var mapContainer = $('#openInterventiMap');
                var emptyState = $('#openInterventiMapEmpty');

                if (!mapContainer.length || typeof L === 'undefined') {
                    return;
                }

                var markersData = (openInterventiRawData || []).map(function (entry) {
                    return {
                        lat: parseCoordinate(entry.lat),
                        lng: parseCoordinate(entry.lng),
                        progressivo: entry.progressivo,
                        specie: entry.specie,
                        settore: entry.settore,
                        collezione: entry.collezione,
                        priorita: entry.priorita,
                        detailUrl: entry.detailUrl,
                        prioritaColore: entry.prioritaColore
                    };
                }).filter(function (entry) {
                    return entry.lat !== null && entry.lng !== null;
                });

                if (markersData.length === 0) {
                    mapContainer.addClass('d-none');
                    emptyState.removeClass('d-none');
                    return;
                }

        function addFullscreenMapControl(map) {
            var FullscreenControl = L.Control.extend({
                options: { position: 'topright' },
                onAdd: function () {
                    var container = L.DomUtil.create('div', 'leaflet-bar');
                    var button = L.DomUtil.create('a', '', container);
                    button.href = '#';
                    button.title = 'Schermo intero';
                    button.setAttribute('role', 'button');
                    button.innerHTML = '&#x26F6;';
                    button.style.fontSize = '18px';
                    button.style.lineHeight = '28px';
                    button.style.textAlign = 'center';

                    L.DomEvent.on(button, 'click', function (e) {
                        L.DomEvent.stop(e);
                        var mapElement = map.getContainer();
                        if (!document.fullscreenElement) {
                            mapElement.requestFullscreen();
                        } else {
                            document.exitFullscreen();
                        }
                    });

                    return container;
                }
            });

            map.addControl(new FullscreenControl());
            if (!map._fullscreenChangeBound) {
                document.addEventListener('fullscreenchange', function () { map.invalidateSize(); });
                map._fullscreenChangeBound = true;
            }
        }

                var map = L.map('openInterventiMap', {
                    scrollWheelZoom: false
                });
                map.attributionControl.setPrefix(false);
                map.attributionControl.setPosition('bottomleft');
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 20,
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

        addFullscreenMapControl(map);

                var bounds = [];
                markersData.forEach(function (item) {
                    var markerHtml = '<span class="map-priority-pin" style="background-color:' + (item.prioritaColore || '#2b7de9') + ';"></span>';
                    var markerIcon = L.divIcon({
                        className: 'map-priority-marker-wrapper',
                        html: markerHtml,
                        iconSize: [20, 20],
                        iconAnchor: [10, 20],
                        popupAnchor: [0, -20]
                    });

                    var marker = L.marker([item.lat, item.lng], { icon: markerIcon }).addTo(map);
                    var popup =
                        '<div><strong>' + (item.progressivo || '-') + '</strong></div>' +
                        '<div>' + (item.specie || '-') + '</div>' +
                        '<div>' + (item.settore || '-') + ' · ' + (item.collezione || '-') + '</div>' +
                        '<div>Priorità: ' + (item.priorita || '-') + '</div>' +
                        '<div class="mt-1"><a href="' + item.detailUrl + '" target="_blank" rel="noopener noreferrer">Elenco interventi</a></div>';

                    marker.bindPopup(popup);
                    bounds.push([item.lat, item.lng]);
                });

                if (bounds.length === 1) {
                    map.setView(bounds[0], 18);
                } else {
                    map.fitBounds(bounds, {
                        padding: [30, 30],
                        maxZoom: 17
                    });
                }
            }

            initializeOpenInterventiMap();

            var lingua = "@ViewBag.lang";
            if (lingua === "en-US") {
                $.extend($.fn.dataTable.defaults, {
                    language: { url: "/js/dataTables.english.json" }
                });
            } else {
                $.extend($.fn.dataTable.defaults, {
                    language: { url: "/js/dataTables.default.json" }
                });
            }

            var baseUrlauto = '@Url.Action("AutoComplete", "InterventiAlberi")';
            $("#nomescientifico").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: baseUrlauto,
                        dataType: "json",
                        data: { term: request.term, field: "nome_scientifico" },
                        success: function (data) { response(data); }
                    });
                }
            });

            var dt = $('#table1').DataTable({
                paging: true,
                lengthChange: true,
                searching: true,
                info: true,
                autoWidth: false,
                ordering: true,

                // ✅ Ordine iniziale: Stato(Aperti) -> Priorità -> Data
                order: [
                    [7, 'desc'],  // Stato: aperto=1, chiuso=0
                    [5, 'desc'],  // Priorità: livello 4->0
                    [6, 'desc']   // Data: ISO
                ]
            });

            var wrapper = $('#table1').closest('.dataTables_wrapper');
            $('#table1HeaderLeft').empty().append(wrapper.find('#table1_length').detach());
            $('#table1HeaderRight').empty().append(wrapper.find('#table1_filter').detach());

            // ✅ NON fare più dt.order([6,'desc']).draw(); altrimenti rovina tutto

            var baseUrlRicerca = '@Url.Action("Ricerca", "InterventiAlberi")';

            $("#cerca").click(function () {
                var prog = ($('#nomescientifico').val() || '').trim();

                if (prog.length < 3) {
                    $("#risultato2Content").html('<div class="alert alert-info mb-0">Inserire almeno 3 caratteri per effettuare la ricerca.</div>');
                    $("#risultato2").removeClass("d-none");
                    return;
                }

                $.ajax({
                    type: "GET",
                    url: baseUrlRicerca,
                    dataType: "json",
                    data: { nome_scientifico: prog },
                    success: function (data) {

                        if (!data || data.length === 0) {
                            $("#risultato2Content").html('<div class="alert alert-warning mb-0">Nessun individuo trovato.</div>');
                            $("#risultato2").removeClass("d-none");
                            return;
                        }

                        var progre = "@language.Getkey("Global_Progressive")";
                        var namesc = "@language.Getkey("Global_Scientific_Name")";
                        var oldprog = "@language.Getkey("Global_Old_Progressive")";
                        var sector = "@language.Getkey("Global_Sector")";
                        var coll = "@language.Getkey("Global_Collection")";
                        var lab = "@language.Getkey("Global_Label")";
                        var individualStatus = "@language.Getkey("Global_Individual_Status")";
                        var add = "@language.Getkey("Global_Add")";
                        var ind = "@language.Getkey("Global_Individual")";

                        var s = '';
                        s += '<table id="tableSearch" class="table table-bordered table-striped table-sm">';
                        s += '<thead><tr>';
                        s += '<th style="width:60px;"></th>';
                        s += '<th>' + progre + '</th>';
                        s += '<th>' + oldprog + '</th>';
                        s += '<th>' + namesc + '</th>';
                        s += '<th>' + sector + '</th>';
                        s += '<th>' + coll + '</th>';
                        s += '<th>' + lab + '</th>';
                        s += '<th>' + individualStatus + '</th>';
                        s += '</tr></thead><tbody>';

                        for (var i = 0; i < data.length; i++) {
                            var indi = data[i].idindividuo;
                            var action = '@Url.Action("Create", "InterventiAlberi")' + '?idindividuo=' + encodeURIComponent(indi);

                            s += '<tr>';
                            s += '<td class="text-center">';
                            s += '<a class="btn btn-success btn-sm" title="' + add + ' ' + ind + '" href="' + action + '">';
                            s += '<i class="fa-solid fa-plus"></i>';
                            s += '</a>';
                            s += '</td>';

                            s += '<td>' + (data[i].progressivo ?? '') + '</td>';
                            s += '<td>' + (data[i].vecchioprogressivo ?? '') + '</td>';
                            s += '<td>' + (data[i].nomescientifico ?? '') + '</td>';
                            s += '<td>' + (data[i].settore ?? '') + '</td>';
                            s += '<td>' + (data[i].collezione ?? '') + '</td>';
                            s += '<td>' + (data[i].cartellino ?? '') + '</td>';
                            s += '<td>' + (data[i].statoindividuo ?? '') + '</td>';
                            s += '</tr>';
                        }

                        s += '</tbody></table>';

                        $("#risultato2Content").html(s);
                        $("#risultato2").removeClass("d-none");

                        if ($.fn.DataTable.isDataTable('#tableSearch')) {
                            $('#tableSearch').DataTable().destroy();
                        }

                        $('#tableSearch').DataTable({
                            paging: true,
                            lengthChange: false,
                            searching: false,
                            info: false,
                            ordering: true,
                            autoWidth: false
                        });
                    },
                    error: function (xhr) {
                        $("#risultato2Content").html(
                            '<div class="alert alert-danger mb-0">Errore durante la ricerca:<br>' + (xhr.responseText ?? '') + '</div>'
                        );
                        $("#risultato2").removeClass("d-none");
                    }
                });
            });

            $('#addIndividuoCollapse')
                .on('shown.bs.collapse', function () {
                    $('#btnToggleAggiungi')
                        .removeClass('btn-primary')
                        .addClass('btn-secondary')
                        .html('<i class="fa-solid fa-xmark"></i> Chiudi');
                })
                .on('hidden.bs.collapse', function () {
                    $('#btnToggleAggiungi')
                        .removeClass('btn-secondary')
                        .addClass('btn-primary')
                        .html('<i class="fa-solid fa-plus"></i> Aggiungi');
                });

        });
    </script>
}
