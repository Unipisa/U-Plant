    <script type="text/javascript">

        var _validFileExtensions = [".jpg", ".jpeg", ".png", ".heif", ".hevc", ".heic"];
        var _maxFileSizeBytes = '@ViewBag.maxupload';
        var messerr1 = '@language.Getkey("Message_20")';
        var messerr2 = '@language.Getkey("Message_21")';
        var messsize1 = '@language.Getkey("Message_22")';
        var messsize2 = '@language.Getkey("Message_23")';


        function validateForm(oForm) {

            var arrInputs = oForm.getElementsByTagName("input");
            for (var i = 0; i < arrInputs.length; i++) {
                var oInput = arrInputs[i];
                if (oInput.type == "file") {
                    var sFileName = oInput.value;
                    if (sFileName.length > 0) {
                        var blnValid = false;
                        for (var j = 0; j < _validFileExtensions.length; j++) {
                            var sCurExtension = _validFileExtensions[j];
                            var estensionefile = sFileName.substr(sFileName.length - sCurExtension.length, sCurExtension.length);
                            if (estensionefile.toLowerCase() == sCurExtension.toLowerCase()) {
                                blnValid = true;
                                break;
                            }
                        }

                        if (!blnValid) {
                          var messerr = messerr1 + estensionefile + messerr2 + _validFileExtensions.join(", ");
                            
                         // var messerr = "Mi dispiace ma, il formato " + estensionefile + " non è valido , le estensioni consentite sono le seguenti : " + _validFileExtensions.join(", ");
                            //alert(messerr);
                            document.getElementById("errore").innerHTML = messerr;
                            document.getElementById("errore").style.display = "block";

                            return false;
                        }

                        if (oInput.files && oInput.files.length > 0) {
                            var f = oInput.files[0];
                            if (f.size > _maxFileSizeBytes) {
                                var messsize = messsize1 + Math.round(f.size / 1024) + messsize2 + Math.round(_maxFileSizeBytes / 1024) + " KB.";
                                document.getElementById("errore").innerHTML = messsize;
                                document.getElementById("errore").style.display = "block";
                                return false;
                            }
                        } else {
                            // Se non è disponibile l'oggetto File (vecchi browser), puoi decidere di ignorare o mostrare avviso diverso
                        }


                    }
                }
            }

            return true;
        }


    </script>



    <script type="text/javascript">
        var _validDocExtensions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string[])ViewBag.allowedDocExtensions));
        var _maxDocFileSizeBytes = @ViewBag.maxuploadDoc;

        function validateDocForm(oForm) {
            var input = oForm.querySelector('input[type="file"]');
            if (!input || !input.files || input.files.length === 0) return false;

            for (var i = 0; i < input.files.length; i++) {
                var file = input.files[i];
                var fileName = (file.name || "").toLowerCase();
                var ok = _validDocExtensions.some(function (e) { return fileName.endsWith(e); });
                if (!ok) {
                    document.getElementById("erroredoc").innerHTML = "Formato documento non valido: " + _validDocExtensions.join(", ");
                    document.getElementById("erroredoc").style.display = "block";
                    return false;
                }

                if (file.size > _maxDocFileSizeBytes) {
                    document.getElementById("erroredoc").innerHTML = "Dimensione file non valida. Max: " + Math.round(_maxDocFileSizeBytes / 1024) + " KB";
                    document.getElementById("erroredoc").style.display = "block";
                    return false;
                }
            }

            document.getElementById("erroredoc").style.display = "none";
            return true;
        }
    </script>

    <script type="text/javascript">
        const defaultLat = 43.71944963861506;
        const defaultLng = 10.396344067111961;
        const latInput = $('#latitudine').val();
        const lngInput = $('#longitudine').val();
        const startLat = latInput ? parseFloat(latInput) : defaultLat;
        const startLng = lngInput ? parseFloat(lngInput) : defaultLng;

        function addFullscreenMapControl(map) {
            var FullscreenControl = L.Control.extend({
                options: { position: 'topright' },
                onAdd: function () {
                    var container = L.DomUtil.create('div', 'leaflet-bar');
                    var button = L.DomUtil.create('a', '', container);
                    button.href = '#';
                    button.title = 'Schermo intero';
                    button.setAttribute('role', 'button');
                    button.innerHTML = '&#x26F6;';
                    button.style.fontSize = '18px';
                    button.style.lineHeight = '28px';
                    button.style.textAlign = 'center';

                    L.DomEvent.on(button, 'click', function (e) {
                        L.DomEvent.stop(e);
                        var mapElement = map.getContainer();
                        if (!document.fullscreenElement) {
                            mapElement.requestFullscreen();
                        } else {
                            document.exitFullscreen();
                        }
                    });

                    return container;
                }
            });

            map.addControl(new FullscreenControl());
            if (!map._fullscreenChangeBound) {
                document.addEventListener('fullscreenchange', function () { map.invalidateSize(); });
                map._fullscreenChangeBound = true;
            }
        }

        const map = L.map('myMap', { scrollWheelZoom: false }).setView([startLat, startLng], 16);
        map.attributionControl.setPrefix(false);
        map.attributionControl.setPosition('bottomleft');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 20,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        addFullscreenMapControl(map);

        function buildColoredMarkerIcon(color) {
            return L.divIcon({
                className: 'map-priority-marker-wrapper',
                html: '<span class="map-priority-pin" style="background-color:' + color + ';"></span>',
                iconSize: [20, 20],
                iconAnchor: [10, 20]
            });
        }

        const settoreColor = '@(Model.settoreNavigation?.colore ?? "#6c757d")';
        L.marker([startLat, startLng], { icon: buildColoredMarkerIcon(settoreColor) }).addTo(map);
    </script>
