@inject LanguageService language
@{
    ViewData["Title"] = "Index";
    var cognome = User.Identities.FirstOrDefault()?.Claims?.Where(c => c.Type == "family_name").FirstOrDefault()?.Value;
    var canSeeWfoImportActions = User.IsInRole("Administrator") && string.Equals(cognome, "Picconi", StringComparison.OrdinalIgnoreCase);
}

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h1 class="card-title">Elenco</h1>
     
           
                <div class="float-right success ">
            @{
                if (canSeeWfoImportActions)
                {
                    <a asp-action="BulkImportWfo" class="mr-2">
                        <span class="btn btn-info" title="Import assistito di un elenco nomi">
                            Import manuale
                        </span>
                    </a>
                    <a asp-action="ImportWfoNomenclature" class="mr-2">
                        <span class="btn btn-primary" title="Import di bootstrap della nomenclatura WFO">
                            Import nomenclatura WFO
                        </span>
                    </a>
          
                    <span class="mr-2" title="@ViewBag.WfoDatasetMessage">
                        @if (ViewBag.WfoDatasetIsLatest == true)
                        {
                            <i class="fa fa-bell text-success" aria-hidden="true"></i>
                        }
                        else
                        {
                            <i class="fa fa-triangle-exclamation text-warning" aria-hidden="true"></i>
                        }
                    </span>
                }
            }
                    <a asp-action="WfoDatabaseAudit" class="mr-2 js-wfo-audit-link">
                        <span class="btn btn-primary" id="btnWfoAuditTop" title="Verifica globale dello stato nomenclaturale rispetto a WFO">
                            Audit WFO DB
                        </span>
                    </a>
                    <a asp-action="Create">
                        <span class="btn btn-success" title="@language.Getkey("Global_Add") @language.Getkey("Global_Species")">
                            @language.Getkey("Global_Add") @language.Getkey("Global_Species")
                        </span>
                    </a>
                </div>
        
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="table1" class="table table-bordered table-striped dataTable">
                <thead>
                    <tr>
                        <th style="width: 110px;">WFO</th>
                        <th>@language.Getkey("Global_Scientific_Name")</th>
                        <th>Validazione tassonomica</th>
                        <th>Data Valutazione</th>
                        <th>Link</th>
                        <th>@language.Getkey("Global_Common_Name")</th>
                        <th>@language.Getkey("Global_English_Common_Name")</th>
                        <th>@language.Getkey("Global_Family")</th>
                        <th>@language.Getkey("Global_Genus")</th>
                        <th>@language.Getkey("Global_Floristic_Kingdom")</th>
                        <th>@language.Getkey("Global_Range")</th>
                        <th>@language.Getkey("Global_Cites")</th>
                        <th>@language.Getkey("Global_Iucn") @language.Getkey("Global_Global")</th>
                        <th>@language.Getkey("Global_Iucn") @language.Getkey("Global_Local")</th>
                        <th>@language.Getkey("Global_Notes")</th>
                        <th style="width:25%"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="wfoModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Verifica World Flora Online</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Chiudi">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="wfoModalBody">Controllo in corso...</div>
                <form id="wfoDecisionForm" asp-action="ApplyWfoDecision" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SpecieId" id="wfoSpecieId" />
                    <input type="hidden" name="ActionType" id="wfoActionType" />
                    <input type="hidden" name="SelectedWfoId" id="wfoSelectedWfoId" />
                    <input type="hidden" name="AcceptedFullName" id="wfoAcceptedFullName" />
                    <input type="hidden" name="Lsid" id="wfoLsid" />
                </form>
            </div>
            <div class="modal-footer" id="wfoModalFooter">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/accessioni.min.css" rel="stylesheet" />
    <link href="~/css/datatables.min.css" rel="stylesheet" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/datatables.min.js"></script>
}

@section CustomScripts {
    <script>
        jQuery(function () {
            const isAdministrator = @User.IsInRole("Administrator").ToString().ToLowerInvariant();
            const editUrlTemplate = '@Url.Action("Edit", "Specie", new { id = "__id__" })';
            const deleteUrlTemplate = '@Url.Action("Delete", "Specie", new { id = "__id__" })';
            const openWfoUrlTemplate = '@Url.Action("OpenWfo", "Specie", new { id = "__id__" })';
            const wfoIconUrl = '@Url.Content("~/img/wfo.png")';

            function renderValidationStatus(value) {
                const normalized = (value || '').toUpperCase();
                if (normalized === 'WFO') {
                    return '<span class="text-success" title="Revisione confermata con WFO"><img src="' + wfoIconUrl + '" alt="WFO" style="width:16px;height:16px;vertical-align:text-bottom;margin-right:4px;" /> ' + value + '</span>';
                }

                if (normalized === 'A.A.') {
                    return '<span class="text-warning" title="Revisione manuale o sinonimo mantenuto"><i class="fa fa-light fa-user-secret"></i> ' + value + '</span>';
                }

                return value || '';
            }

            function renderLinks(row) {
                const openWfoUrl = openWfoUrlTemplate.replace('__id__', row.id);
                let html = '<div class="small"><a href="' + openWfoUrl + '" target="_blank" rel="noopener noreferrer">WFO</a>';

                if (row.lsid) {
                    const encodedLsid = encodeURIComponent(row.lsid.trim());
                    html += ' | <a href="https://www.ipni.org/n/' + encodedLsid + '" target="_blank" rel="noopener noreferrer">IPNI</a>';
                    html += ' | <a href="https://powo.science.kew.org/taxon/' + encodedLsid + '" target="_blank" rel="noopener noreferrer">POWO</a>';
                }

                html += '</div>';
                return html;
            }

            function renderActions(row) {
                if (!isAdministrator || !row.showActions) {
                    return '';
                }

                const editUrl = editUrlTemplate.replace('__id__', row.id);
                let actions = '<a href="' + editUrl + '"><span class="btn btn-warning btn-xs"><i class="fa-solid fa-pencil" style="color: #fafafa;"></i></span></a>';

                if (row.canDelete) {
                    const deleteUrl = deleteUrlTemplate.replace('__id__', row.id);
                    actions += ' <a href="' + deleteUrl + '"><span class="btn btn-danger btn-xs"><i class="fa-solid fa-trash"></i></span></a>';
                }

                return actions;
            }

            const table = jQuery('#table1').DataTable({
                'processing': true,
                'deferRender': true,
                'paging': true,
                'lengthChange': true,
                'searching': true,
                'ordering': true,
                'info': true,
                'autoWidth': false,
                'pageLength': 25,
                'lengthMenu': [25, 50, 100],
                'searchDelay': 400,
                'ajax': {
                    'url': '@Url.Action("IndexAllData", "Specie")',
                    'type': 'POST',
                    'dataSrc': function (json) {
                        return json && json.data ? json.data : [];
                    },
                    'error': function (xhr) {
                        console.error('Specie IndexAllData error', xhr);
                    }
                },
                'order': [[1, 'asc']],
                'columns': [
                    {
                        'data': null,
                        'orderable': false,
                        'searchable': false,
                        'render': function (data, type, row) {
                            if (!isAdministrator) {
                                return '';
                            }

                            const scientificName = $('<div>').text(row.scientificName || '').html();
                            return '<button type="button" class="btn btn-info btn-xs js-wfo-check" data-id="' + row.id + '" data-name="' + scientificName + '" title="Verifica World Flora Online"><i class="fa-solid fa-globe"></i></button>';
                        }
                    },
                    { 'data': 'scientificName' },
                    {
                        'data': 'validationStatus',
                        'render': function (data) {
                            return renderValidationStatus(data);
                        }
                    },
                    { 'data': 'insertedAt' },
                    {
                        'data': null,
                        'render': function (data, type, row) {
                            return renderLinks(row);
                        }
                    },
                    { 'data': 'commonName' },
                    { 'data': 'englishCommonName' },
                    { 'data': 'family' },
                    { 'data': 'genus' },
                    { 'data': 'kingdom' },
                    { 'data': 'range' },
                    { 'data': 'cites' },
                    { 'data': 'iucnGlobal' },
                    { 'data': 'iucnLocal' },
                    { 'data': 'notePreview' },
                    {
                        'data': null,
                        'orderable': false,
                        'searchable': false,
                        'render': function (data, type, row) {
                            return renderActions(row);
                        }
                    }
                ]
            });

            let wfoServiceAvailable = true;

            function setWfoButtonsAvailability(isAvailable, message) {
                wfoServiceAvailable = isAvailable;
                const buttons = jQuery('.js-wfo-check');
                const auditButton = jQuery('#btnWfoAuditTop');
                const auditLink = jQuery('.js-wfo-audit-link');
                buttons.removeClass('btn-info btn-danger btn-secondary');
                buttons.addClass(isAvailable ? 'btn-info' : 'btn-danger');
                buttons.attr('title', isAvailable ? 'Verifica World Flora Online' : (message || 'Servizio WFO non disponibile'));
                buttons.attr('data-wfo-available', isAvailable ? 'true' : 'false');

                auditButton.removeClass('btn-primary btn-danger');
                auditButton.addClass(isAvailable ? 'btn-primary' : 'btn-danger');
                auditButton.attr('title', isAvailable ? 'Verifica globale dello stato nomenclaturale rispetto a WFO' : (message || 'Servizio WFO non disponibile'));
                auditButton.attr('data-wfo-available', isAvailable ? 'true' : 'false');
                auditLink.attr('aria-disabled', isAvailable ? 'false' : 'true');
            }

            function showWfoUnavailableMessage(message) {
                const modal = $('#wfoModal');
                $('#wfoModalBody').html('<p>' + (message || 'Il servizio World Flora Online non risponde al momento.') + '</p>');
                $('#wfoModalFooter').html('<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>');
                modal.modal('show');
            }

            function submitWfoDecision(actionType, specieId, wfoId, acceptedFullName, lsid) {
                $('#wfoSpecieId').val(specieId || '');
                $('#wfoActionType').val(actionType || '');
                $('#wfoSelectedWfoId').val(wfoId || '');
                $('#wfoAcceptedFullName').val(acceptedFullName || '');
                $('#wfoLsid').val(lsid || '');
                $('#wfoDecisionForm').trigger('submit');
            }

            function normalizeScientificName(value) {
                return (value || '').replace(/\s+/g, ' ').trim().toLowerCase();
            }

            function checkWfoStatus() {
                $.get('@Url.Action("WfoStatus", "Specie")')
                    .done(function (data) {
                        setWfoButtonsAvailability(!!data.serviceAvailable, data.message);
                    })
                    .fail(function () {
                        setWfoButtonsAvailability(false, 'Servizio WFO non disponibile');
                    });
            }

            checkWfoStatus();
            table.on('draw', function () {
                setWfoButtonsAvailability(wfoServiceAvailable, wfoServiceAvailable ? 'Verifica World Flora Online' : 'Servizio WFO non disponibile');
            });

            jQuery('.js-wfo-audit-link').on('click', function (event) {
                if (wfoServiceAvailable) {
                    return;
                }

                event.preventDefault();
                showWfoUnavailableMessage('Il servizio World Flora Online non risulta disponibile in questo momento.');
            });

            jQuery('#table1 tbody').on('click', '.js-wfo-check', function () {
                var specieId = $(this).data('id');
                var scientificName = $(this).data('name');
                var modal = $('#wfoModal');

                if (!wfoServiceAvailable) {
                    showWfoUnavailableMessage('Il servizio World Flora Online non risulta disponibile in questo momento.');
                    return;
                }

                $('#wfoModalBody').html('<p>Controllo WFO in corso per <strong>' + scientificName + '</strong>...</p>');
                $('#wfoModalFooter').html('<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>');
                modal.modal('show');

                $.get('@Url.Action("CheckWfo", "Specie")', { id: specieId })
                    .done(function (data) {
                        if (data.serviceAvailable === false) {
                            setWfoButtonsAvailability(false, data.message);
                            showWfoUnavailableMessage(data.message);
                            return;
                        }

                        if (data.status === 'accepted' && data.match) {
                            if (normalizeScientificName(data.currentScientificName) === normalizeScientificName(data.match.fullName)) {
                                $('#wfoModalBody').html(
                                    '<p><strong>' + data.match.fullName + '</strong> coincide con il nome gia presente.</p>' +
                                    '<p>Posso salvarlo subito come accettato WFO e valorizzare l\'LSID.</p>' +
                                    '<p><strong>LSID WFO:</strong> ' + (data.match.lsid || 'non restituito da WFO') + '</p>'
                                );
                                $('#wfoModalFooter').html(
                                    '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                                    '<button type="button" class="btn btn-success js-save-direct-wfo">Salva come accettato</button>'
                                );
                                $('.js-save-direct-wfo').on('click', function () {
                                    submitWfoDecision('accept_suggested', specieId, data.match.wfoId, data.match.fullName, data.match.lsid);
                                });
                                return;
                            }

                            $('#wfoModalBody').html(
                                '<p><strong>' + data.match.fullName + '</strong> risulta un nome accettato in World Flora Online.</p>' +
                                '<p>Puoi aprire la revisione per vedere e modificare i campi prima del salvataggio.</p>' +
                                '<p><strong>LSID IPNI:</strong> ' + (data.match.lsid || 'non restituito da WFO') + '</p>'
                            );
                            $('#wfoModalFooter').html(
                                '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                                '<a class="btn btn-success" href="' + data.reviewUrl + '">Apri revisione WFO</a>'
                            );
                            return;
                        }

                        if (data.status === 'synonym' && data.match) {
                            if (normalizeScientificName(data.currentScientificName) === normalizeScientificName(data.match.acceptedName)) {
                                $('#wfoModalBody').html(
                                    '<p>Il nome accettato proposto da WFO coincide con quello gia presente.</p>' +
                                    '<p>Posso salvare subito stato WFO e LSID.</p>' +
                                    '<p><strong>LSID WFO:</strong> ' + (data.match.lsid || 'non restituito da WFO') + '</p>'
                                );
                                $('#wfoModalFooter').html(
                                    '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                                    '<button type="button" class="btn btn-success js-save-direct-wfo">Salva come accettato</button>'
                                );
                                $('.js-save-direct-wfo').on('click', function () {
                                    submitWfoDecision('keep_current', specieId, data.match.wfoId, data.match.acceptedName, data.match.lsid);
                                });
                                return;
                            }

                            $('#wfoModalBody').html(
                                '<p><strong>' + data.match.fullName + '</strong> risulta un sinonimo.</p>' +
                                '<p>Nome accettato proposto da WFO: <strong>' + data.match.acceptedName + '</strong></p>' +
                                '<p>Apri la revisione per scegliere quale proposta caricare nel form prima del salvataggio.</p>' +
                                '<p><strong>LSID WFO:</strong> ' + (data.match.lsid || 'non restituito da WFO') + '</p>'
                            );
                            $('#wfoModalFooter').html(
                                '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                                '<a class="btn btn-primary" href="' + data.reviewUrl + '">Apri revisione WFO</a>'
                            );
                            return;
                        }

                        var body = '<p>Il check WFO non ha trovato un match univoco.</p>';
                        if (data.candidates && data.candidates.length > 0) {
                            body += '<p>Sono stati trovati ' + data.candidates.length + ' candidati possibili.</p>';
                        }
                        body += '<p>Ti apro la pagina di revisione per gestire il caso manualmente.</p>';
                        $('#wfoModalBody').html(body);
                        $('#wfoModalFooter').html(
                            '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                            '<a class="btn btn-primary" href="' + data.reviewUrl + '">Apri revisione</a>'
                        );
                    })
                    .fail(function (xhr) {
                        setWfoButtonsAvailability(false, 'Servizio WFO non disponibile');
                        var message = 'Non sono riuscito a contattare il servizio WFO in questo momento.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            message = xhr.responseJSON.message;
                        }
                        showWfoUnavailableMessage(message);
                    });
            });
        });
    </script>
}
