@model UPlant.Models.DB.InterventiAlberi
@inject LanguageService language
@{
    ViewBag.Title = @language.Getkey("Global_Individual");
}

<p>
    @if (string.Equals(ViewBag.source as string, "ricerca", System.StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="RicercaTabella" asp-controller="InterventiAlberi">
            <span class="btn btn btn-info " title="@language.Getkey("Global_Go_Back")">
                @language.Getkey("Global_Go_Back")
            </span>
        </a>
    }
    else
    {
        <a asp-action="ElencoInterventi" asp-controller="InterventiAlberi" asp-route-id="@Model.individuo">
            <span class="btn btn btn-info " title="@language.Getkey("Global_Go_Back")">
                @language.Getkey("Global_Go_Back")
            </span>
        </a>
    }
</p>

<div class="col-lg-12">
    <div class="card card-primary">
        <div class="card-header with-border">
            <h3 class="card-title font-weight-bold">
                @(ViewData["nomescientifico"] ?? "") - @(ViewData["progressivo"] ?? "")
            </h3>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="card-body">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <input type="hidden" asp-for="id" />
                <input type="hidden" asp-for="individuo" />
                <input type="hidden" asp-for="dataapertura" />
                <input type="hidden" asp-for="utenteapertura" />
                <input type="hidden" asp-for="utenteultimamodifica" />
                <input type="hidden" name="source" value="@(ViewBag.source ?? string.Empty)" />
                <div class="row">
                    <div class="form-group col">
                        <label asp-for="priorita" class="control-label">@language.Getkey("Global_Tree_Priority")</label>
                        <select asp-for="priorita" class="form-control" asp-items="ViewBag.priorita"></select>
                        <span asp-validation-for="priorita" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="statoIntervento" class="control-label">@language.Getkey("Global_Intervention_Status")</label>
                        <select asp-for="statoIntervento" class="form-control">
                            <option value="false">Aperto</option>
                            <option value="true">Chiuso</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="form-group col">
                        <label asp-for="intervento" class="control-label">@language.Getkey("Global_Intervention")</label>
                        <select asp-for="intervento" class="form-control" asp-items="ViewBag.intervento"></select>
                        <span asp-validation-for="intervento" class="text-danger"></span>
                    </div>
                    <div class="form-group col">
                        <label asp-for="fornitore" class="control-label">@language.Getkey("Global_Service_Provider")</label>
                        <select asp-for="fornitore" class="form-control" asp-items="ViewBag.fornitore"></select>
                        <span asp-validation-for="fornitore" class="text-danger"></span>
                    </div>
                </div>

                <hr />
                <div class="row text-center font-weight-bold">@language.Getkey("Global_Details")</div>
                <hr />

                <div class="row">
                    <div class="form-group col">
                        <label asp-for="motivo" class="control-label">@language.Getkey("Global_Reason")</label>
                        <input asp-for="motivo" class="form-control" />
                        <span asp-validation-for="motivo" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="form-group col">
                        <label asp-for="esitointervento" class="control-label">@language.Getkey("Global_Outcome")</label>
                        <input asp-for="esitointervento" class="form-control" />
                        <span asp-validation-for="esitointervento" class="text-danger"></span>
                    </div>
                </div>

                <div class="row" id="statoCondizioneRow">
                    <div class="form-group col">
                        <label class="control-label">@language.Getkey("Global_Individual_Status")</label>
                        <select asp-for="statoIndividuo" class="form-control"
                                asp-items="@(ViewData["statoIndividuo"] as SelectList)"></select>
                    </div>

                    <div class="form-group col">
                        <label class="control-label">@language.Getkey("Global_Condition")</label>
                        <select asp-for="condizione" class="form-control"
                                asp-items="@(ViewData["condizione"] as SelectList)"></select>
                    </div>
                </div>

                <hr />
                <div class="form-group">
                    <input type="submit" value="@language.Getkey("Global_Save")" class="btn btn-primary" />
                </div>
            </div>
        }

    </div>

    <p>
        @if (string.Equals(ViewBag.source as string, "ricerca", System.StringComparison.OrdinalIgnoreCase))
        {
            <a asp-action="RicercaTabella" asp-controller="InterventiAlberi">
                <span class="btn btn btn-info " title="@language.Getkey("Global_Go_Back")">
                    @language.Getkey("Global_Go_Back")
                </span>
            </a>
        }
        else
        {
            <a asp-action="ElencoInterventi" asp-controller="InterventiAlberi" asp-route-id="@Model.individuo">
                <span class="btn btn btn-info " title="@language.Getkey("Global_Go_Back")">
                    @language.Getkey("Global_Go_Back")
                </span>
            </a>
        }
    </p>
</div>

@section Scripts {
    <script src="~/js/jquery.validation.min.js"></script>
}

@section CustomScripts {
    <script>
        $(function () {
            var isClosed = String($('#statoIntervento').val()).toLowerCase() === 'true';

            function updateStatoCondizioneEditable() {
                var closed = String($('#statoIntervento').val()).toLowerCase() === 'true';
                $('#statoIndividuo').prop('disabled', !closed).trigger('change');
                $('#condizione').prop('disabled', !closed).trigger('change');
                $('#esitointervento').prop('required', closed);
            }

            if (!isClosed) {
                $('#statoIntervento').on('change', updateStatoCondizioneEditable);
            }

            updateStatoCondizioneEditable();
        });
    </script>
}
