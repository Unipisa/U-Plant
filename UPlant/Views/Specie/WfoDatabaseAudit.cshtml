@model UPlant.Models.ViewModels.SpecieWfoDatabaseAuditViewModel

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h3 class="card-title">Verifica globale WFO</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-secondary">
            <strong>Riferimento audit:</strong> dataset ufficiale WFO Plant List @Model.OfficialDatasetLabel.
        </div>
        <p>Questo controllo analizza le specie ancora da validare e divide i risultati in gruppi utili alla revisione.</p>
        <p>Puoi limitare quante righe elaborare in questo run e scegliere quali esiti vuoi raccogliere.</p>

        <div class="alert alert-info">
            <div><strong>Specie da controllare:</strong> @Model.TotalSpeciesCount</div>
            <div><strong>Gia marcate WFO:</strong> @Model.AlreadyWfoCount</div>
            @if (Model.HasCachedAudit && Model.CachedAuditUpdatedAtUtc.HasValue)
            {
                <div><strong>Ultimo audit salvato:</strong> @Model.CachedAuditUpdatedAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</div>
            }
        </div>

        <form id="wfoAuditStartForm" asp-action="StartWfoDatabaseAudit" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="MaxSpeciesToProcess">Righe da processare</label>
                        <input id="MaxSpeciesToProcess" name="MaxSpeciesToProcess" type="number" min="1" max="500" value="@Model.DefaultMaxSpeciesToProcess" class="form-control" />
                        <small class="form-text text-muted">Consigliato: 20 per volta.</small>
                    </div>
                </div>
                <div class="col-md-9">
                    <label class="d-block">Esiti da raccogliere</label>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludePerfectAccepted" name="IncludePerfectAccepted" value="true" @(Model.DefaultIncludePerfectAccepted ? "checked" : null) />
                        <label class="form-check-label" for="IncludePerfectAccepted">Coincidono</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludePerfectSynonym" name="IncludePerfectSynonym" value="true" @(Model.DefaultIncludePerfectSynonym ? "checked" : null) />
                        <label class="form-check-label" for="IncludePerfectSynonym">Sinonimi</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludeAmbiguous" name="IncludeAmbiguous" value="true" @(Model.DefaultIncludeAmbiguous ? "checked" : null) />
                        <label class="form-check-label" for="IncludeAmbiguous">Piu opzioni</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludeUnchecked" name="IncludeUnchecked" value="true" @(Model.DefaultIncludeUnchecked ? "checked" : null) />
                        <label class="form-check-label" for="IncludeUnchecked">Unchecked</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludeUnplaced" name="IncludeUnplaced" value="true" @(Model.DefaultIncludeUnplaced ? "checked" : null) />
                        <label class="form-check-label" for="IncludeUnplaced">Unplaced</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="IncludeNoMatch" name="IncludeNoMatch" value="true" @(Model.DefaultIncludeNoMatch ? "checked" : null) />
                        <label class="form-check-label" for="IncludeNoMatch">Nessun match</label>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary" id="btnStartWfoAudit">Avvia verifica globale WFO</button>
            <a asp-action="Index" class="btn btn-info">Indietro</a>
        </form>

        <div id="wfoAuditProgressPanel" class="mt-3" style="display:none;">
            <div class="alert alert-info">
                <div><strong>Stato audit:</strong> <span id="wfoAuditStage">In attesa</span></div>
                <div class="mt-1"><strong>Elemento corrente:</strong> <span id="wfoAuditCurrentItem">-</span></div>
                <div class="progress mt-3">
                    <div id="wfoAuditProgressBar" class="progress-bar progress-bar-striped active" role="progressbar" style="width:0%">0%</div>
                </div>
                <div class="mt-2 small" id="wfoAuditCounters" style="color:#111;">Controllate 0 di @Model.TotalSpeciesCount specie</div>
            </div>
        </div>

        <div class="card card-outline card-info mt-3" id="wfoAuditRecentPanel" style="display:none;">
            <div class="card-header with-border">
                <h3 class="card-title">Ultime verifiche</h3>
            </div>
            <div class="card-body">
                <ul id="wfoAuditRecentMessages" class="mb-0 pl-3"></ul>
            </div>
        </div>

        <div id="wfoAuditErrorPanel" class="mt-3" style="display:none;"></div>
        <div id="wfoAuditServicePanel" class="mt-3" style="display:none;"></div>
        <div id="wfoAuditResultsPanel" class="mt-3" style="display:none;"></div>

        <form id="wfoAuditApplyForm" asp-action="ApplyWfoAcceptedFromAudit" method="post" style="display:none;">
            @Html.AntiForgeryToken()
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const startForm = document.getElementById('wfoAuditStartForm');
            const applyForm = document.getElementById('wfoAuditApplyForm');
            if (!startForm || !window.fetch) {
                return;
            }

            const startButton = document.getElementById('btnStartWfoAudit');
            const progressPanel = document.getElementById('wfoAuditProgressPanel');
            const recentPanel = document.getElementById('wfoAuditRecentPanel');
            const resultsPanel = document.getElementById('wfoAuditResultsPanel');
            const errorPanel = document.getElementById('wfoAuditErrorPanel');
            const servicePanel = document.getElementById('wfoAuditServicePanel');
            const stageEl = document.getElementById('wfoAuditStage');
            const currentItemEl = document.getElementById('wfoAuditCurrentItem');
            const progressBarEl = document.getElementById('wfoAuditProgressBar');
            const countersEl = document.getElementById('wfoAuditCounters');
            const recentMessagesEl = document.getElementById('wfoAuditRecentMessages');
            const antiForgeryToken = applyForm.querySelector('input[name="__RequestVerificationToken"]').value;
            const cachedAuditJson = @Html.Raw(string.IsNullOrWhiteSpace(Model.CachedAuditJson) ? "null" : Model.CachedAuditJson);
            let pollHandle = null;
            let wfoServiceAvailable = true;

            function normalizeList(values) {
                if (Array.isArray(values)) {
                    return values;
                }

                if (values && Array.isArray(values.$values)) {
                    return values.$values;
                }

                if (values && typeof values === 'object') {
                    return Object.values(values);
                }

                return [];
            }

            function setProgress(percent) {
                const value = Math.max(0, Math.min(100, percent || 0));
                progressBarEl.style.width = value + '%';
                progressBarEl.textContent = value + '%';
            }

            function setWfoAuditAvailability(isAvailable, message) {
                wfoServiceAvailable = !!isAvailable;
                startButton.disabled = !wfoServiceAvailable;
                startButton.classList.remove('btn-primary', 'btn-danger');
                startButton.classList.add(wfoServiceAvailable ? 'btn-primary' : 'btn-danger');
                startButton.title = wfoServiceAvailable
                    ? 'Avvia verifica globale WFO'
                    : (message || 'Servizio WFO non disponibile');

                if (wfoServiceAvailable) {
                    servicePanel.style.display = 'none';
                    servicePanel.innerHTML = '';
                    return;
                }

                servicePanel.innerHTML = '<div class="alert alert-danger"><strong>' +
                    escapeHtml(message || 'Il servizio World Flora Online non risulta disponibile in questo momento.') +
                    '</strong></div>';
                servicePanel.style.display = '';
            }

            function renderRecentMessages(messages) {
                recentMessagesEl.innerHTML = '';
                normalizeList(messages).forEach(function (message) {
                    if (typeof message !== 'string') {
                        return;
                    }

                    const li = document.createElement('li');
                    li.textContent = message;
                    recentMessagesEl.appendChild(li);
                });
            }

            function escapeHtml(value) {
                return (value || '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function renderSection(title, key, rows) {
                const normalizedRows = normalizeList(rows);
                const emptyText = key === 'perfectAccepted'
                    ? 'Nessuna specie trovata in questa sezione.'
                    : (key === 'perfectSynonym'
                        ? 'Nessun sinonimo confermato trovato.'
                        : (key === 'ambiguous'
                            ? 'Nessuna specie con piu candidati WFO.'
                            : (key === 'unchecked'
                                ? 'Nessuna specie con stato WFO unchecked.'
                                : (key === 'unplaced'
                                    ? 'Nessuna specie con stato WFO unplaced.'
                                    : 'Nessuna specie senza match perfetto.'))));

                let body = '';
                if (!normalizedRows.length) {
                    body = '<div class="text-muted">' + emptyText + '</div>';
                } else {
                    body = '<div class="table-responsive"><table class="table table-bordered table-striped">' +
                        '<thead><tr><th>Nome specie</th><th>Esito WFO</th><th>Validazione attuale</th><th style="width:220px;">Azione</th></tr></thead><tbody>';

                    normalizedRows.forEach(function (row) {
                        const scientificName = escapeHtml(row.scientificName || row.ScientificName);
                        const acceptedNameRaw = row.acceptedName || row.AcceptedName || '';
                        const acceptedName = escapeHtml(acceptedNameRaw);
                        const notes = escapeHtml(row.notes || row.Notes);
                        const validation = escapeHtml(row.currentValidationStatus || row.CurrentValidationStatus || '-');
                        const specieId = row.specieId || row.SpecieId;
                        const lsid = escapeHtml(row.lsid || row.Lsid || '');
                        const familyName = escapeHtml(row.familyName || row.FamilyName || '');
                        const alreadyWfo = validation === 'WFO';
                        const actionHtml = key === 'perfectAccepted'
                            ? (alreadyWfo
                                ? '<span class="badge badge-success">Gia WFO</span>'
                                : '<button type="button" class="btn btn-success btn-sm js-audit-apply" data-specie-id="' + specieId + '" data-lsid="' + lsid + '">OK</button>')
                            : (key === 'perfectSynonym'
                                ? (alreadyWfo
                                    ? '<span class="badge badge-success">Gia WFO</span>'
                                    : '<div class="btn-group" role="group">' +
                                        '<button type="button" class="btn btn-success btn-sm mr-1 js-audit-apply" data-specie-id="' + specieId + '" data-lsid="' + lsid + '" data-accepted-full-name="' + acceptedName + '" data-family-name="' + familyName + '">OK</button>' +
                                        '<a class="btn btn-info btn-sm" href="@Url.Action("ReviewWfo", "Specie")/' + specieId + '?returnToAudit=true">Rivedi</a>' +
                                      '</div>')
                                : '<a class="btn btn-info btn-sm" href="@Url.Action("ReviewWfo", "Specie")/' + specieId + '?returnToAudit=true">Rivedi</a>');

                        body += '<tr>' +
                            '<td><strong>' + scientificName + '</strong></td>' +
                            '<td>' + (acceptedName ? '<div><strong>' + acceptedName + '</strong></div>' : '') + '<div class="small text-muted">' + notes + '</div></td>' +
                            '<td>' + validation + '</td>' +
                            '<td>' + actionHtml + '</td>' +
                            '</tr>';
                    });

                    body += '</tbody></table></div>';
                }

                return '<div class="card card-outline card-primary mt-3">' +
                    '<div class="card-header with-border"><h3 class="card-title">' + title + '</h3></div>' +
                    '<div class="card-body">' + body + '</div></div>';
            }

            function isSectionEnabled(status, camelName, pascalName) {
                const camelValue = status ? status[camelName] : undefined;
                if (typeof camelValue === 'boolean') {
                    return camelValue;
                }

                const pascalValue = status ? status[pascalName] : undefined;
                if (typeof pascalValue === 'boolean') {
                    return pascalValue;
                }

                return true;
            }

            function renderResults(status) {
                let html = '';
                if (isSectionEnabled(status, 'includePerfectAccepted', 'IncludePerfectAccepted')) {
                    html += renderSection('1. Nomi che coincidono perfettamente con WFO e risultano accettati', 'perfectAccepted', status.perfectAccepted || status.PerfectAccepted);
                }
                if (isSectionEnabled(status, 'includePerfectSynonym', 'IncludePerfectSynonym')) {
                    html += renderSection('2. Nomi che fanno match ma risultano sinonimi con conferme WFO', 'perfectSynonym', status.perfectSynonym || status.PerfectSynonym);
                }
                if (isSectionEnabled(status, 'includeAmbiguous', 'IncludeAmbiguous')) {
                    html += renderSection('3. Nomi per cui WFO propone piu opzioni', 'ambiguous', status.ambiguous || status.Ambiguous);
                }
                if (isSectionEnabled(status, 'includeUnchecked', 'IncludeUnchecked')) {
                    html += renderSection('4. Nomi presenti in WFO con stato unchecked', 'unchecked', status.unchecked || status.Unchecked);
                }
                if (isSectionEnabled(status, 'includeUnplaced', 'IncludeUnplaced')) {
                    html += renderSection('5. Nomi presenti in WFO con stato unplaced', 'unplaced', status.unplaced || status.Unplaced);
                }
                if (isSectionEnabled(status, 'includeNoMatch', 'IncludeNoMatch')) {
                    html += renderSection('6. Nomi che non fanno match', 'noMatch', status.noMatch || status.NoMatch);
                }

                resultsPanel.innerHTML = html || '<div class="alert alert-info">Nessun gruppo selezionato per la visualizzazione.</div>';
                resultsPanel.style.display = '';
            }

            async function pollStatus(statusUrl) {
                const response = await fetch(statusUrl, { headers: { 'Accept': 'application/json' } });
                if (!response.ok) {
                    throw new Error('Non riesco a leggere lo stato dell\'audit.');
                }

                const status = await response.json();
                progressPanel.style.display = '';
                recentPanel.style.display = '';
                stageEl.textContent = status.stage || status.Stage || 'In esecuzione';
                currentItemEl.textContent = status.currentItem || status.CurrentItem || '-';
                countersEl.textContent = 'Controllate ' + (status.checkedSpecies || status.CheckedSpecies || 0) + ' di ' + (status.totalSpecies || status.TotalSpecies || 0) + ' specie';
                setProgress(status.percent || status.Percent || 0);
                renderRecentMessages(status.recentMessages || status.RecentMessages);

                if ((status.status || status.Status) === 'completed') {
                    clearInterval(pollHandle);
                    pollHandle = null;
                    startButton.disabled = false;
                    renderResults(status);
                    return;
                }

                if ((status.status || status.Status) === 'failed') {
                    clearInterval(pollHandle);
                    pollHandle = null;
                    startButton.disabled = false;
                    errorPanel.innerHTML = '<div class="alert alert-danger"><strong>' + escapeHtml(status.errorMessage || status.ErrorMessage || 'Audit interrotto.') + '</strong></div>';
                    errorPanel.style.display = '';
                }
            }

            async function startAudit() {
                if (!wfoServiceAvailable) {
                    setWfoAuditAvailability(false, 'Il servizio World Flora Online non risulta disponibile in questo momento.');
                    return;
                }

                startButton.disabled = true;
                progressPanel.style.display = '';
                recentPanel.style.display = '';
                resultsPanel.style.display = 'none';
                errorPanel.style.display = 'none';
                stageEl.textContent = 'Avvio audit';
                currentItemEl.textContent = '-';
                countersEl.textContent = 'Controllate 0 di @Model.TotalSpeciesCount specie';
                setProgress(0);
                renderRecentMessages(['Preparazione audit globale WFO...']);

                try {
                    const response = await fetch(startForm.action, {
                        method: 'POST',
                        body: new FormData(startForm),
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        }
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        throw new Error(payload.message || 'Non sono riuscito ad avviare l\'audit.');
                    }

                    if (payload.cached && payload.snapshot) {
                        progressPanel.style.display = '';
                        recentPanel.style.display = '';
                        stageEl.textContent = payload.snapshot.stage || payload.snapshot.Stage || 'Audit completato';
                        currentItemEl.textContent = payload.snapshot.currentItem || payload.snapshot.CurrentItem || '-';
                        countersEl.textContent = 'Controllate ' + (payload.snapshot.checkedSpecies || payload.snapshot.CheckedSpecies || 0) + ' di ' + (payload.snapshot.totalSpecies || payload.snapshot.TotalSpecies || 0) + ' specie';
                        setProgress(payload.snapshot.percent || payload.snapshot.Percent || 100);
                        renderRecentMessages(payload.snapshot.recentMessages || payload.snapshot.RecentMessages);
                        renderResults(payload.snapshot);
                        startButton.disabled = false;
                        return;
                    }

                    await pollStatus(payload.statusUrl);
                    pollHandle = setInterval(function () {
                        pollStatus(payload.statusUrl).catch(function (error) {
                            clearInterval(pollHandle);
                            pollHandle = null;
                            startButton.disabled = false;
                            errorPanel.innerHTML = '<div class="alert alert-danger"><strong>' + escapeHtml(error.message) + '</strong></div>';
                            errorPanel.style.display = '';
                        });
                    }, 1800);
                } catch (error) {
                    startButton.disabled = false;
                    errorPanel.innerHTML = '<div class="alert alert-danger"><strong>' + escapeHtml(error.message) + '</strong></div>';
                    errorPanel.style.display = '';
                }
            }

            async function checkWfoStatus() {
                try {
                    const response = await fetch('@Url.Action("WfoStatus", "Specie")', { headers: { 'Accept': 'application/json' } });
                    if (!response.ok) {
                        throw new Error();
                    }

                    const payload = await response.json();
                    setWfoAuditAvailability(!!payload.serviceAvailable, payload.message);
                } catch {
                    setWfoAuditAvailability(false, 'Servizio WFO non disponibile.');
                }
            }

            startForm.addEventListener('submit', async function (event) {
                event.preventDefault();
                await startAudit();
            });

            async function applyAuditAccepted(button, autoCreateMissingGenus) {
                try {
                    const formData = new FormData();
                    formData.append('__RequestVerificationToken', antiForgeryToken);
                    formData.append('SpecieId', button.dataset.specieId);
                    formData.append('Lsid', button.dataset.lsid || '');
                    formData.append('AcceptedFullName', button.dataset.acceptedFullName || '');
                    formData.append('FamilyName', button.dataset.familyName || '');
                    formData.append('AutoCreateMissingGenus', autoCreateMissingGenus ? 'true' : 'false');

                    const response = await fetch(applyForm.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        }
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        if (payload && payload.requiresGenusCreation) {
                            const confirmationMessage = payload.message || ('Manca il genere ' + (payload.genusName || '') + '. Vuoi inserirlo automaticamente?');
                            if (confirm(confirmationMessage)) {
                                await applyAuditAccepted(button, true);
                                return;
                            }
                            if (payload.reviewUrl) {
                                window.location.href = payload.reviewUrl;
                                return;
                            }
                            button.disabled = false;
                            return;
                        }
                        throw new Error(payload.message || 'Non sono riuscito a salvare il match WFO.');
                    }

                    const row = button.closest('tr');
                    if (row) {
                        row.remove();
                    }
                } catch (error) {
                    button.disabled = false;
                    alert(error.message);
                }
            }

            resultsPanel.addEventListener('click', async function (event) {
                const button = event.target.closest('.js-audit-apply');
                if (!button) {
                    return;
                }

                button.disabled = true;
                await applyAuditAccepted(button, false);
            });

            if (cachedAuditJson) {
                progressPanel.style.display = '';
                recentPanel.style.display = '';
                stageEl.textContent = cachedAuditJson.stage || cachedAuditJson.Stage || 'Audit completato';
                currentItemEl.textContent = cachedAuditJson.currentItem || cachedAuditJson.CurrentItem || '-';
                countersEl.textContent = 'Controllate ' + (cachedAuditJson.checkedSpecies || cachedAuditJson.CheckedSpecies || 0) + ' di ' + (cachedAuditJson.totalSpecies || cachedAuditJson.TotalSpecies || 0) + ' specie';
                setProgress(cachedAuditJson.percent || cachedAuditJson.Percent || 100);
                renderRecentMessages(cachedAuditJson.recentMessages || cachedAuditJson.RecentMessages);
                renderResults(cachedAuditJson);
            }

            checkWfoStatus();
        })();
    </script>
}
