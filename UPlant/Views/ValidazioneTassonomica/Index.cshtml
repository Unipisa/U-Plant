@model IEnumerable<UPlant.Models.DB.ValidazioneTassonomica>
@inject LanguageService language
@{
    ViewData["Title"] = "Index";
}

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h1 class="card-title">Elenco</h1>
        @if (User.IsInRole("Administrator"))
        {
            <div class="float-right success">
                <a asp-action="Create">
                    <span class="btn btn-success" title="Aggiungi Validazione tassonomica">
                        Aggiungi Validazione tassonomica
                    </span>
                </a>
            </div>
        }
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="table1" class="table table-bordered table-striped dataTable">
                <thead>
                    <tr>
                        <th>Descrizione</th>
                        <th>Descrizione EN</th>
                        <th>Ordinamento</th>
                        <th>Organizzazione</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.descrizione</td>
                            <td>@item.descrizione_en</td>
                            <td>@item.ordinamento</td>
                            <td>@item.organizzazioneNavigation?.descrizione</td>
                            <td>
                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.id">
                                        <span class="btn btn-warning btn-xs"><i class="fa-solid fa-pencil" style="color: #fafafa;"></i></span>
                                    </a>
                                    if (!item.Specie.Any())
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.id">
                                            <span class="btn btn-danger btn-xs"><i class="fa-solid fa-trash"></i></span>
                                        </a>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/css/datatables.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/js/datatables.min.js"></script>
}

@section CustomScripts {
    <script>
        jQuery(function () {
            jQuery('#table1').DataTable({
                'paging': true,
                'lengthChange': true,
                'searching': true,
                'ordering': true,
                'info': true,
                'autoWidth': false
            })
        })
    </script>
}


