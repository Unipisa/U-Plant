@inject LanguageService language
@{
    ViewData["Title"] = "Index";
}

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h1 class="card-title">Elenco</h1>
        @{
            if (User.IsInRole("Administrator"))
            {
                <div class="float-right success ">
                    <a asp-action="BulkImportWfo" class="mr-2">
                        <span class="btn btn-info" title="Import massivo da WFO">
                            Import WFO
                        </span>
                    </a>
                    <a asp-action="Create">
                        <span class="btn btn-success" title="@language.Getkey("Global_Add") @language.Getkey("Global_Species")">
                            @language.Getkey("Global_Add") @language.Getkey("Global_Species")
                        </span>
                    </a>
                </div>
            }
        }
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="table1" class="table table-bordered table-striped dataTable">
                                <thead>
                                    <tr>
                                        <th style="width: 110px;">
                                            WFO
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Scientific_Name")
                                        </th>
                                        <th>
                                            Status nomenclaturale
                                        </th>
                                        <th>
                                            Data
                                        </th>
                                        <th>
                                            LSID
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Common_Name")
                                        </th>
                                        <th>
                                        @language.Getkey("Global_English_Common_Name")
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Family")
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Genus")
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Floristic_Kingdom")
                                        </th>
                                        <th>
                                        @language.Getkey("Global_Range")
                                        </th>
                                        <th>
                            @language.Getkey("Global_Cites")
                                        </th>
                                        <th>
                            @language.Getkey("Global_Iucn") @language.Getkey("Global_Global")
                                        </th>
                                        <th>
                            @language.Getkey("Global_Iucn") @language.Getkey("Global_Local")
                                        </th>
                        <th>
                            @language.Getkey("Global_Notes") 
                        </th>
                                        <th style="width:25%"></th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @foreach (var item in Model)
                                    {
                                    <tr>
                                        <td class="text-center">
                                            @if (User.IsInRole("Administrator"))
                                            {
                                                <button type="button"
                                                        class="btn btn-info btn-xs js-wfo-check"
                                                        data-id="@item.id"
                                                        data-name="@item.nome_scientifico"
                                                        title="Verifica World Flora Online">
                                                    <i class="fa-solid fa-globe"></i>
                                                </button>
                                            }
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nome_scientifico)
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.status_nomenclaturaleNavigation?.descrizione) &&
                                           item.status_nomenclaturaleNavigation.descrizione.Equals("WFO", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="text-success" title="Revisione confermata con WFO">
                                                    <i class="fa-solid fa-circle-check"></i> @item.status_nomenclaturaleNavigation.descrizione
                                                </span>
                                            }
                                            else
                                            {
                                                @Html.DisplayFor(modelItem => item.status_nomenclaturaleNavigation.descrizione)
                                            }
                                        </td>
                                        <td>
                                            @item.data_inserimento.ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                        <td>
                                            @($"{Trunc(item.lsid ?? "", 40)}{(string.IsNullOrEmpty(item.lsid) ? "" : "...")}")
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nome_comune)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nome_comune_en)
                                        </td>
                                        <td>
                                @Html.DisplayFor(modelItem => item.genereNavigation.famigliaNavigation.descrizione)
                                        </td>

                                        <td>
                                @Html.DisplayFor(modelItem => item.genereNavigation.descrizione)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.regnoNavigation.descrizione)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.arealeNavigation.descrizione)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.citesNavigation.codice)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.iucn_globaleNavigation.codice)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.iucn_italiaNavigation.codice)
                                        </td>
                            <td>
                                @($"{Trunc(item.note ?? "", 100)}{(string.IsNullOrEmpty(item.note) ? "" : " [...]")}")
                                                            </td>
                                        <td>
                                @if (User.IsInRole("Administrator"))
                                {

                                    <a asp-action="Edit" asp-route-id="@item.id">
                                        <span class="btn btn-warning btn-xs" title="@language.Getkey("Global_Edit") @language.Getkey("Global_Species") ">
                                            <i class="fa-solid fa-pencil" style="color: #fafafa;"></i>
                                        </span>
                                    </a>
                                      if (@item.Accessioni.Count() == 0)
                                                {
                                    <a asp-action="Delete" asp-route-id="@item.id">
                                            <span class="btn btn-danger btn-xs" title="@language.Getkey("Global_Delete") @language.Getkey("Global_Spicies")">
                                            <i class="fa-solid fa-trash"></i>
                                        </span>
                                    </a>
                                        }
                                }

                                        
                                        </td>
                                    </tr>
                                    }

                            </table>
                        </div>
                    </div>


                </div>

<div class="modal fade" id="wfoModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Verifica World Flora Online</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Chiudi">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="wfoModalBody">Controllo in corso...</div>
                <form id="wfoDecisionForm" asp-action="ApplyWfoDecision" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SpecieId" id="wfoSpecieId" />
                    <input type="hidden" name="ActionType" id="wfoActionType" />
                    <input type="hidden" name="SelectedWfoId" id="wfoSelectedWfoId" />
                    <input type="hidden" name="AcceptedFullName" id="wfoAcceptedFullName" />
                    <input type="hidden" name="Lsid" id="wfoLsid" />
                </form>
            </div>
            <div class="modal-footer" id="wfoModalFooter">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>
@section Styles {
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/accessioni.min.css" rel="stylesheet" />
    <link href="~/css/datatables.min.css" rel="stylesheet" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/datatables.min.js"></script>
}

@section CustomScripts {
    <script>
        jQuery(function () {
            const isAdministrator = @User.IsInRole("Administrator").ToString().ToLowerInvariant();
            const editUrlTemplate = '@Url.Action("Edit", "Specie", new { id = "__id__" })';
            const deleteUrlTemplate = '@Url.Action("Delete", "Specie", new { id = "__id__" })';

            jQuery('#table1').DataTable({
                'processing': true,
                'deferRender': true,
                'paging': true,
                'lengthChange': true,
                'searching': true,
                'ordering': true,
                'info': true,
                'autoWidth': false,
                'pageLength': 25,
                'lengthMenu': [25, 50, 100],
                'searchDelay': 400,
                'ajax': {
                    'url': '@Url.Action("IndexAllData", "Specie")',
                    'type': 'POST',
                    'dataSrc': function (json) {
                        if (json && json.data && Array.isArray(json.data.$values)) {
                            return json.data.$values;
                        }

                        return json && json.data ? json.data : [];
                    },
                    'error': function (xhr) {
                        console.error('Specie IndexData error', xhr);
                    }
                },
                'order': [[0, 'asc']],
                'columns': [
                    { 'data': 'scientificName' },
                    { 'data': 'commonName' },
                    { 'data': 'englishCommonName' },
                    { 'data': 'family' },
                    { 'data': 'genus' },
                    { 'data': 'kingdom' },
                    { 'data': 'range' },
                    { 'data': 'cites' },
                    { 'data': 'iucnGlobal' },
                    { 'data': 'iucnLocal' },
                    { 'data': 'notePreview' },
                    {
                        'data': null,
                        'orderable': false,
                        'searchable': false,
                        'render': function (data, type, row) {
                            if (!isAdministrator || !row.showActions) {
                                return '';
                            }

                            const editUrl = editUrlTemplate.replace('__id__', row.id);
                            let actions = '<a href="' + editUrl + '"><span class="btn btn-warning btn-xs"><i class="fa-solid fa-pencil" style="color: #fafafa;"></i></span></a>';

                            if (row.canDelete) {
                                const deleteUrl = deleteUrlTemplate.replace('__id__', row.id);
                                actions += ' <a href="' + deleteUrl + '"><span class="btn btn-danger btn-xs"><i class="fa-solid fa-trash"></i></span></a>';
                            }

                            return actions;
                        }
                    }
                ]
            });
        })
    </script>
    <script>
        function submitWfoDecision(actionType, specieId, wfoId, acceptedFullName, lsid) {
            $('#wfoSpecieId').val(specieId || '');
            $('#wfoActionType').val(actionType || '');
            $('#wfoSelectedWfoId').val(wfoId || '');
            $('#wfoAcceptedFullName').val(acceptedFullName || '');
            $('#wfoLsid').val(lsid || '');
            $('#wfoDecisionForm').submit();
        }

        $(function () {
            $('.js-wfo-check').on('click', function () {
                var specieId = $(this).data('id');
                var scientificName = $(this).data('name');
                var modal = $('#wfoModal');
                $('#wfoModalBody').html('<p>Controllo WFO in corso per <strong>' + scientificName + '</strong>...</p>');
                $('#wfoModalFooter').html('<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>');
                modal.modal('show');

                $.get('@Url.Action("CheckWfo", "Specie")', { id: specieId })
                    .done(function (data) {
                        if (data.status === 'accepted' && data.match) {
                            $('#wfoModalBody').html(
                                '<p><strong>' + data.match.fullName + '</strong> risulta un nome accettato in World Flora Online.</p>' +
                                '<p>Vuoi confermare la revisione e impostare lo status nomenclaturale a WFO?</p>'
                            );
                            $('#wfoModalFooter').html(
                                '<button type="button" class="btn btn-secondary" data-dismiss="modal">Annulla</button>' +
                                '<button type="button" class="btn btn-success" onclick="submitWfoDecision(\'accept_suggested\', \'' + specieId + '\', \'' + data.match.wfoId + '\', \'' + (data.match.fullName || '').replace(/'/g, '&#39;') + '\', \'' + (data.match.lsid || '') + '\')">Conferma revisione</button>'
                            );
                            return;
                        }

                        if (data.status === 'synonym' && data.match) {
                            $('#wfoModalBody').html(
                                '<p><strong>' + data.match.fullName + '</strong> risulta un sinonimo.</p>' +
                                '<p>Nome accettato proposto da WFO: <strong>' + data.match.acceptedName + '</strong></p>'
                            );
                            $('#wfoModalFooter').html(
                                '<button type="button" class="btn btn-secondary" data-dismiss="modal">Annulla</button>' +
                                '<button type="button" class="btn btn-warning" onclick="submitWfoDecision(\'keep_current\', \'' + specieId + '\', \'' + data.match.wfoId + '\', \'' + (data.match.fullName || '').replace(/'/g, '&#39;') + '\', \'' + (data.match.lsid || '') + '\')">Lascia il nome attuale</button>' +
                                '<button type="button" class="btn btn-success" onclick="submitWfoDecision(\'accept_suggested\', \'' + specieId + '\', \'' + data.match.wfoId + '\', \'' + (data.match.acceptedName || '').replace(/'/g, '&#39;') + '\', \'' + (data.match.lsid || '') + '\')">Usa il nome accettato</button>'
                            );
                            return;
                        }

                        var body = '<p>Il check WFO non ha trovato un match univoco.</p>';
                        if (data.candidates && data.candidates.length > 0) {
                            body += '<p>Sono stati trovati ' + data.candidates.length + ' candidati possibili.</p>';
                        }
                        body += '<p>Ti apro la pagina di revisione per gestire il caso manualmente.</p>';
                        $('#wfoModalBody').html(body);
                        $('#wfoModalFooter').html(
                            '<button type="button" class="btn btn-secondary" data-dismiss="modal">Chiudi</button>' +
                            '<a class="btn btn-primary" href="' + data.reviewUrl + '">Apri revisione</a>'
                        );
                    })
                    .fail(function () {
                        $('#wfoModalBody').html('<p>Non sono riuscito a contattare il servizio WFO in questo momento.</p>');
                    });
            });
        });
    </script>
}          
