@model UPlant.Models.DB.StatusNomenclaturale

<div class="card card-outline card-primary">
    <div class="card-header with-border">
        <h3 class="card-title">Aggiungi status nomenclaturale</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="descrizione" class="control-label"></label>
                <input asp-for="descrizione" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="descrizione_en" class="control-label"></label>
                <input asp-for="descrizione_en" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="ordinamento" class="control-label"></label>
                <input asp-for="ordinamento" class="form-control" value="@ViewData["ordinesuccessivo"]" />
            </div>
            <div class="form-group">
                <label asp-for="organizzazione" class="control-label"></label>
                <select asp-for="organizzazione" class="form-control" asp-items="ViewBag.organizzazione"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Crea" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-info">Indietro</a>
</div>
